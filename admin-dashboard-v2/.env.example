# Copy to .env / Netlify environment. See docs/MASTER_TENANT.md

# --- Supabase (service role on server) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Dashboard auth ---
ADMIN_SESSION_SECRET=
DASHBOARD_ADMIN_PASSWORD=

# --- Tenant / template (same UUID as YCode TEMPLATE_TENANT_ID) ---
TEMPLATE_TENANT_ID=2fff887d-a78e-4256-9116-6e02fe38c614
TENANT_DOMAIN_SUFFIX=masjidweb.com

# Public Supabase (if used by client-side dashboard)
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# --- Links & provisioning ---
# Per-tenant builder + live site: https://{slug}.<TENANT_DOMAIN_SUFFIX>/ycode — no separate manage URL.
# (Legacy) MANAGE_SITE_URL was used when a global builder host existed; omit in new setups.

# Must match YCode Netlify site exactly (min 16 chars)
PROVISIONING_WEBHOOK_SECRET=

# YCode pool base URL for server-to-server publish after provision (no trailing slash).
# Strongly recommended: use the *.netlify.app hostname (e.g. https://masjidweb-multi.netlify.app)
# so new tenant subdomains work before per-host SSL is ready. Optional alias: NETLIFY_YCODE_SITE_URL.
# YCODE_SITE_INTERNAL_URL=
# NETLIFY_YCODE_SITE_URL=

# --- Netlify API (provision pipeline) ---
NETLIFY_AUTH_TOKEN=
# Multi-tenant site (tenant subdomains), used by provisioning APIs.
NETLIFY_SITE_ID=
# Optional: YCode builder Netlify site — deploy list + rollback on /dashboard/updates (defaults to NETLIFY_SITE_ID if unset)
# NETLIFY_UPDATES_DEPLOY_SITE_ID=

# --- GitHub (Platform Updates on /dashboard/updates: compare fork, sync, merge PRs) ---
# Fine-grained or classic PAT with Contents read/write on the fork repo; repo scope for merge-upstream.
GITHUB_TOKEN=
# Fork to manage (org/repo)
GITHUB_REPO=mywebmasteruk/ycode-masjidweb
# Optional: branch GitHub merges upstream into (defaults to the fork’s default branch on GitHub)
# GITHUB_SYNC_BRANCH=main
# Optional: comma-separated base branches for “Sync Pull Requests” (default: tenant-multi only).
# Optional: GITHUB_SYNC_PR_BASES=tenant-multi
