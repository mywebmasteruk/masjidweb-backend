---
interface Props { title: string; }
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style is:global>
    :root {
      --bg: #0f1117;
      --bg-card: #181a20;
      --bg-card-hover: #1e2028;
      --bg-surface: #23252d;
      --border: #2a2d38;
      --border-focus: #6366f1;
      --text: #e4e5ea;
      --text-secondary: #9395a0;
      --text-muted: #63657a;
      --accent: #6366f1;
      --accent-hover: #818cf8;
      --accent-subtle: rgba(99,102,241,.12);
      --success: #22c55e;
      --success-bg: rgba(34,197,94,.1);
      --warning: #eab308;
      --warning-bg: rgba(234,179,8,.1);
      --danger: #ef4444;
      --danger-bg: rgba(239,68,68,.1);
      --radius: 10px;
      --radius-lg: 14px;
      --shadow: 0 1px 2px rgba(0,0,0,.3), 0 4px 16px rgba(0,0,0,.2);
      --transition: 150ms cubic-bezier(.4,0,.2,1);
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
    body {
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.55;
      min-height: 100vh;
    }

    .shell { display: flex; min-height: 100vh; }
    .sidebar {
      width: 240px; flex-shrink: 0;
      background: var(--bg-card);
      border-right: 1px solid var(--border);
      padding: 1.5rem 1rem;
      display: flex; flex-direction: column;
      position: sticky; top: 0; height: 100vh;
    }
    .sidebar-brand {
      display: flex; align-items: center; gap: .6rem;
      padding: .25rem .5rem; margin-bottom: 2rem;
    }
    .sidebar-brand-icon {
      width: 32px; height: 32px; border-radius: 8px;
      background: linear-gradient(135deg, var(--accent), #a78bfa);
      display: flex; align-items: center; justify-content: center;
      font-weight: 700; font-size: .8rem; color: #fff;
    }
    .sidebar-brand span { font-weight: 700; font-size: .95rem; letter-spacing: -.02em; }
    .sidebar-nav { flex: 1; display: flex; flex-direction: column; gap: .25rem; }
    .sidebar-link {
      display: flex; align-items: center; gap: .6rem;
      padding: .55rem .75rem; border-radius: var(--radius);
      font-size: .85rem; font-weight: 500; color: var(--text-secondary);
      text-decoration: none; transition: all var(--transition);
    }
    .sidebar-link:hover, .sidebar-link.active {
      background: var(--accent-subtle); color: var(--accent-hover);
    }
    .sidebar-link svg { width: 18px; height: 18px; flex-shrink: 0; opacity: .7; }
    .sidebar-link.active svg { opacity: 1; }
    .sidebar-footer { margin-top: auto; padding-top: 1rem; border-top: 1px solid var(--border); }

    .main { flex: 1; padding: 2rem 2.5rem; max-width: 1200px; overflow-x: hidden; }

    h1 { font-size: 1.5rem; font-weight: 700; letter-spacing: -.03em; margin-bottom: .25rem; }
    h2 { font-size: 1.05rem; font-weight: 600; letter-spacing: -.02em; color: var(--text); }
    .page-desc { font-size: .85rem; color: var(--text-muted); margin-bottom: 1.5rem; }

    .card {
      background: var(--bg-card); border: 1px solid var(--border);
      border-radius: var(--radius-lg); padding: 1.5rem;
      box-shadow: var(--shadow); margin-bottom: 1.25rem;
      transition: border-color var(--transition);
    }
    .card:hover { border-color: #363846; }
    .card-header {
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 1rem; gap: 1rem;
    }

    table { width: 100%; border-collapse: collapse; font-size: .835rem; }
    thead th {
      padding: .6rem .85rem; text-align: left;
      font-size: .7rem; font-weight: 600; text-transform: uppercase; letter-spacing: .06em;
      color: var(--text-muted); border-bottom: 1px solid var(--border);
      background: transparent;
    }
    tbody td {
      padding: .7rem .85rem; border-bottom: 1px solid var(--border);
      vertical-align: middle;
    }
    tbody tr { transition: background var(--transition); }
    tbody tr:hover { background: var(--bg-card-hover); }
    tbody tr:last-child td { border-bottom: none; }

    input, select, textarea {
      width: 100%; padding: .6rem .85rem;
      background: var(--bg-surface); color: var(--text);
      border: 1px solid var(--border); border-radius: var(--radius);
      font-family: inherit; font-size: .85rem;
      transition: border-color var(--transition), box-shadow var(--transition);
      outline: none;
    }
    input::placeholder, textarea::placeholder { color: var(--text-muted); }
    input:focus, textarea:focus, select:focus {
      border-color: var(--border-focus);
      box-shadow: 0 0 0 3px var(--accent-subtle);
    }
    label { display: block; font-size: .75rem; font-weight: 600; margin-bottom: .35rem; color: var(--text-secondary); text-transform: uppercase; letter-spacing: .04em; }
    .field { margin-bottom: .85rem; }

    .btn {
      display: inline-flex; align-items: center; justify-content: center; gap: .4rem;
      padding: .55rem 1.1rem; border: none; border-radius: var(--radius);
      cursor: pointer; font-family: inherit; font-size: .835rem; font-weight: 600;
      transition: all var(--transition); outline: none;
      text-decoration: none;
    }
    .btn:disabled { opacity: .5; cursor: not-allowed; }
    .btn-primary { background: var(--accent); color: #fff; }
    .btn-primary:hover:not(:disabled) { background: var(--accent-hover); transform: translateY(-1px); }
    .btn-ghost { background: transparent; color: var(--text-secondary); border: 1px solid var(--border); }
    .btn-ghost:hover { background: var(--bg-surface); color: var(--text); border-color: #464860; }
    .btn-danger-ghost { background: transparent; color: var(--danger); border: 1px solid rgba(239,68,68,.3); }
    .btn-danger-ghost:hover { background: var(--danger-bg); border-color: rgba(239,68,68,.5); }
    .btn-sm { padding: .35rem .7rem; font-size: .78rem; border-radius: 7px; }

    .badge {
      display: inline-flex; align-items: center; gap: .3rem;
      padding: .2rem .6rem; border-radius: 999px;
      font-size: .7rem; font-weight: 600; letter-spacing: .02em;
    }
    .badge::before { content: ''; width: 6px; height: 6px; border-radius: 50%; }
    .badge-green { background: var(--success-bg); color: var(--success); }
    .badge-green::before { background: var(--success); }
    .badge-yellow { background: var(--warning-bg); color: var(--warning); }
    .badge-yellow::before { background: var(--warning); }
    .badge-red { background: var(--danger-bg); color: var(--danger); }
    .badge-red::before { background: var(--danger); }
    .badge-gray { background: rgba(99,102,124,.12); color: var(--text-muted); }
    .badge-gray::before { background: var(--text-muted); }
    .badge-muted { background: rgba(99,101,122,.18); color: var(--text-secondary); }
    .badge-muted::before { background: var(--text-secondary); }

    a { color: var(--accent-hover); text-decoration: none; }
    a:hover { text-decoration: underline; }

    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: .85rem; }
    @media (max-width: 640px) { .grid-2 { grid-template-columns: 1fr; } }

    .flex { display: flex; align-items: center; gap: .75rem; }
    .hidden { display: none; }
    .text-sm { font-size: .8rem; }
    .text-xs { font-size: .72rem; }
    .text-muted { color: var(--text-muted); }
    .text-secondary { color: var(--text-secondary); }
    .mono { font-family: 'SF Mono', SFMono-Regular, ui-monospace, Menlo, monospace; }
    .truncate { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 260px; }
    .empty-state { text-align: center; padding: 2.5rem 1rem; color: var(--text-muted); font-size: .85rem; }

    #toast {
      position: fixed; top: 1.25rem; right: 1.25rem;
      padding: .75rem 1.15rem; border-radius: var(--radius);
      font-size: .835rem; font-weight: 500; z-index: 200;
      display: none; backdrop-filter: blur(12px);
      animation: slideIn .25s ease-out;
    }
    @keyframes slideIn { from { opacity: 0; transform: translateX(12px); } to { opacity: 1; transform: translateX(0); } }
    .toast-ok { background: var(--success-bg); color: var(--success); border: 1px solid rgba(34,197,94,.25); }
    .toast-err { background: var(--danger-bg); color: var(--danger); border: 1px solid rgba(239,68,68,.25); }

    .form-reveal {
      overflow: hidden; max-height: 0; opacity: 0;
      transition: max-height .35s ease, opacity .25s ease, padding .25s ease;
      padding-top: 0;
    }
    /* Tall forms (template + grid + long helper copy) exceeded 960px; overflow:hidden clipped
       the submit row so clicks hit the tenant tab bar below. */
    .form-reveal.open {
      max-height: 5000px; opacity: 1; padding-top: 1.25rem;
      overflow: visible;
      border-top: 1px solid var(--border); margin-top: 1rem;
      position: relative;
      z-index: 4;
    }
    /* Prevent table head / rows from sitting above the provision form (click interception). */
    .card table { position: relative; z-index: 0; }
    .card table thead th { position: static; }

    @media (max-width: 800px) {
      .sidebar { display: none; }
      .main { padding: 1.25rem; }
    }
  </style>
</head>
<body>
  <div id="toast"></div>
  <slot />
</body>
</html>
