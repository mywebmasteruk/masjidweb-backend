---
import Layout from "../../layouts/Layout.astro";

const cleanupDeletesUnassigned =
  import.meta.env.AUTH_CLEANUP_DELETE_UNASSIGNED === "true" ||
  import.meta.env.AUTH_CLEANUP_DELETE_UNASSIGNED === "1" ||
  String(import.meta.env.AUTH_CLEANUP_DELETE_UNASSIGNED ?? "").toLowerCase() === "yes";
---

<Layout title="Maintenance — MasjidWeb Admin">
  <div class="shell">
    <aside class="sidebar">
      <div class="sidebar-brand">
        <div class="sidebar-brand-icon">MW</div>
        <span>MasjidWeb</span>
      </div>
      <nav class="sidebar-nav">
        <a href="/dashboard" class="sidebar-link">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
          Tenants
        </a>
        <a href="/dashboard/logs" class="sidebar-link">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          Logs
        </a>
        <a href="/dashboard/maintenance" class="sidebar-link active">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          Maintenance
        </a>
      </nav>
      <div class="sidebar-footer">
        <button id="logoutBtn" class="sidebar-link" style="width:100%;border:none;background:none;cursor:pointer;text-align:left;font-family:inherit;">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
          Log out
        </button>
      </div>
    </aside>

    <main class="main">
      <div style="margin-bottom:1.5rem;">
        <h1>Maintenance</h1>
        <p class="page-desc" style="margin-bottom:0;">Prepare safe platform updates, rollbacks, and cleanup jobs from one place.</p>
      </div>

      <div class="card core-update-card">
        <div class="card-header">
          <div>
            <h2>Core Update</h2>
            <p class="text-xs text-muted" style="margin:.35rem 0 0;">Update the live builder safely. Production stays unchanged until you approve.</p>
          </div>
          <button id="checkUpdatesBtn" class="btn btn-ghost btn-sm">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
            Refresh status
          </button>
        </div>

        <div id="statusArea" style="margin-bottom:1rem;">
          <div class="status-placeholder">
            <p class="text-sm text-muted">Checking safe core update status...</p>
          </div>
        </div>


        <div class="flex core-update-actions" style="flex-wrap:wrap;gap:.75rem;align-items:center;margin-top:1rem;">
          <button type="button" id="applyBuilderUpdateBtn" class="btn btn-primary">Prepare safe update</button>
          <a id="openPreviewBtn" class="btn btn-ghost hidden" href="#" target="_blank" rel="noopener noreferrer">Open MasjidDemo1 builder preview</a>
          <a id="safeUpdatePrLink" class="btn btn-ghost hidden" href="#" target="_blank" rel="noopener noreferrer">Open pull request</a>
        </div>
        <div id="applyUpdateResult" class="hidden text-xs" style="margin-top:.75rem;padding:.75rem;border-radius:var(--radius);border:1px solid var(--border);"></div>
      </div>

      <div class="card recovery-card">
        <div class="card-header">
          <div>
            <h2>Recovery</h2>
            <p class="text-xs text-muted" style="margin:.35rem 0 0;">Rollback the live builder if an approved update causes trouble. This does not undo a Git merge; it restores the previous Netlify production build.</p>
          </div>
          <button type="button" id="restorePreviousDeployBtn" class="btn btn-ghost">Restore previous live build</button>
        </div>
        <div id="historyArea" class="history-wrap">
          <p class="text-sm text-muted" style="margin:0;">Previous live builder builds load with the update check.</p>
        </div>
      </div>

      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1rem;align-items:start;">
        <div class="card">
          <div class="card-header">
            <h2>Database cleanup</h2>
          </div>
          <p class="text-sm text-muted" style="margin-top:-.35rem;line-height:1.6;">
            Removes CMS/YCode rows whose tenant no longer exists, repairs Auth users from their tenant slug where possible, and clears stale builder invites.
          </p>
          {cleanupDeletesUnassigned ? (
            <p class="text-xs" style="padding:.75rem;border-radius:var(--radius);background:rgba(234,179,8,.08);border:1px solid rgba(234,179,8,.28);color:var(--warning);line-height:1.5;">
              This server is configured to also delete Auth users with no tenant_id and no tenant_slug, except preserved emails.
            </p>
          ) : null}
          <button type="button" id="cleanupOrphansBtn" class="btn btn-primary" style="margin-top:.75rem;">
            Cleanup orphan rows
          </button>
          <div id="rowCleanupResult" class="text-xs text-muted" style="margin-top:.75rem;line-height:1.5;"></div>
        </div>

        <div class="card">
          <div class="card-header">
            <h2>Subdomain cleanup</h2>
          </div>
          <p class="text-sm text-muted" style="margin-top:-.35rem;line-height:1.6;">
            Finds Netlify tenant subdomains under the platform domain that no longer have a tenant row, then removes only the confirmed orphan aliases.
          </p>
          <button type="button" id="cleanupDomainAliasesBtn" class="btn btn-primary" style="margin-top:.75rem;">
            Cleanup orphan subdomains
          </button>
          <div id="domainCleanupResult" class="text-xs text-muted" style="margin-top:.75rem;line-height:1.5;"></div>
        </div>
      </div>
    </main>
  </div>

  <div id="historyModal" class="history-modal hidden" role="dialog" aria-modal="true" aria-labelledby="historyModalTitle">
    <div class="history-modal-backdrop" data-history-modal-close></div>
    <div class="history-modal-panel">
      <div class="history-modal-header">
        <h2 id="historyModalTitle">Update details</h2>
        <button type="button" class="history-modal-close" data-history-modal-close>Close</button>
      </div>
      <div id="historyModalBody" class="text-sm text-muted" style="line-height:1.65;"></div>
      <div id="historyModalActions" class="flex hidden" style="gap:.75rem;justify-content:flex-end;margin-top:1rem;"></div>
    </div>
  </div>

  <div id="toast" style="display:none;position:fixed;right:1rem;bottom:1rem;z-index:9999;padding:.9rem 1.1rem;border-radius:var(--radius);box-shadow:var(--shadow-lg);font-size:.9rem;"></div>

  <style>
    .status-placeholder { padding: .75rem 0; }
    .core-update-state {
      padding: 1rem;
      border: 1px solid rgba(148, 163, 184, .22);
      border-radius: var(--radius);
      background: rgba(15, 23, 42, .28);
    }
    .core-update-topline {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: .6rem;
      margin-bottom: .65rem;
    }
    .core-update-pill {
      display: inline-flex;
      align-items: center;
      border-radius: 999px;
      padding: .18rem .55rem;
      font-size: .72rem;
      font-weight: 700;
      border: 1px solid rgba(34, 197, 94, .24);
      background: var(--success-bg);
      color: var(--success);
    }
    .core-update-pill.pending {
      border-color: rgba(234, 179, 8, .32);
      background: rgba(234, 179, 8, .08);
      color: var(--warning);
    }
    .core-update-stepper {
      margin: .85rem 0 1rem;
      padding: 0;
      list-style: none;
      display: flex;
      flex-wrap: wrap;
      gap: .35rem;
    }
    .core-update-stepper-item {
      flex: 1 1 0;
      min-width: 4.5rem;
    }
    .core-update-stepper-btn {
      width: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: .35rem;
      padding: .45rem .35rem;
      border-radius: calc(var(--radius) - 2px);
      border: 1px solid rgba(148, 163, 184, .18);
      background: rgba(255, 255, 255, .02);
      color: var(--muted);
      cursor: pointer;
      font-family: inherit;
      transition: border-color .15s ease, background .15s ease, color .15s ease;
    }
    .core-update-stepper-btn:hover {
      border-color: rgba(148, 163, 184, .35);
      color: var(--text);
    }
    .core-update-stepper-btn.viewing {
      border-color: rgba(59, 130, 246, .45);
      background: rgba(59, 130, 246, .1);
      color: var(--text);
    }
    .core-update-stepper-btn.done .core-update-stepper-dot {
      border-color: rgba(34, 197, 94, .45);
      background: var(--success-bg);
      color: var(--success);
    }
    .core-update-stepper-btn.current:not(.viewing) .core-update-stepper-dot {
      border-color: rgba(59, 130, 246, .5);
      box-shadow: 0 0 0 2px rgba(59, 130, 246, .18);
    }
    .core-update-stepper-btn.skipped .core-update-stepper-dot {
      opacity: .55;
    }
    .core-update-stepper-dot {
      width: 1.65rem;
      height: 1.65rem;
      border-radius: 999px;
      border: 1px solid rgba(148, 163, 184, .35);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: .72rem;
      font-weight: 700;
      line-height: 1;
    }
    .core-update-stepper-label {
      font-size: .68rem;
      font-weight: 600;
      text-align: center;
      line-height: 1.25;
    }
    .core-update-step-panel {
      padding: .85rem 0 0;
      border-top: 1px solid rgba(148, 163, 184, .14);
    }
    .core-update-step-badge {
      display: inline-flex;
      margin-bottom: .5rem;
      border-radius: 999px;
      padding: .15rem .5rem;
      font-size: .68rem;
      font-weight: 700;
      letter-spacing: .02em;
    }
    .core-update-step-badge.live {
      border: 1px solid rgba(59, 130, 246, .35);
      background: rgba(59, 130, 246, .1);
      color: #93c5fd;
    }
    .core-update-step-badge.done {
      border: 1px solid rgba(34, 197, 94, .28);
      background: var(--success-bg);
      color: var(--success);
    }
    .core-update-step-badge.skipped {
      border: 1px solid rgba(148, 163, 184, .22);
      background: rgba(148, 163, 184, .08);
      color: var(--muted);
    }
    .core-update-step-badge.upcoming {
      border: 1px solid rgba(148, 163, 184, .22);
      color: var(--muted);
    }
    .core-update-wizard-nav {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      gap: .65rem;
      margin-top: 1rem;
      padding-top: .85rem;
      border-top: 1px solid rgba(148, 163, 184, .14);
    }
    .core-update-headline {
      margin: 0;
      font-size: 1.05rem;
      font-weight: 650;
      color: var(--text);
      line-height: 1.35;
    }
    .core-update-guide {
      margin: .45rem 0 0;
      font-size: .85rem;
      line-height: 1.6;
      color: var(--muted);
    }
    .core-update-version {
      margin: .65rem 0 0;
      line-height: 1.5;
    }
    .core-update-preview-panel {
      margin-top: 1rem;
      padding: .85rem;
      border-radius: calc(var(--radius) - 2px);
      border: 1px solid rgba(59, 130, 246, .28);
      background: rgba(59, 130, 246, .06);
    }
    .core-update-preview-links {
      display: flex;
      flex-wrap: wrap;
      gap: .5rem;
      margin-top: .65rem;
    }
    .core-update-preview-picker {
      margin-top: .65rem;
    }
    .preview-tenant-select {
      width: 100%;
      max-width: 28rem;
      padding: .5rem .65rem;
      border-radius: var(--radius);
      border: 1px solid var(--border);
      background: rgba(15, 23, 42, .45);
      color: var(--text);
      font-size: .85rem;
    }
    .core-update-preview-warn {
      margin: .55rem 0 0;
      padding: .55rem .65rem;
      border-radius: calc(var(--radius) - 2px);
      border: 1px solid rgba(234, 179, 8, .32);
      background: rgba(234, 179, 8, .08);
      color: var(--warning);
      font-size: .78rem;
      line-height: 1.5;
    }
    .history-wrap { overflow: visible; }
    .history-table {
      width: 100%;
      border-collapse: collapse;
      font-size: .8rem;
    }
    .history-table th,
    .history-table td {
      text-align: left;
      padding: .55rem .4rem;
      border-bottom: 1px solid var(--border);
      vertical-align: top;
    }
    .history-table th { color: var(--muted); font-weight: 600; }
    :global(.sr-only) {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }
    .history-badge-live {
      display: inline-block;
      padding: .1rem .4rem;
      border-radius: 999px;
      background: var(--success-bg);
      color: var(--success);
      border: 1px solid rgba(34,197,94,.22);
      font-size: .72rem;
      font-weight: 600;
    }
    :global(.history-table th:last-child),
    :global(.history-table td:last-child) {
      text-align: right;
      width: 3rem;
    }
    :global(.history-actions) { position: relative; display: inline-flex; justify-content: flex-end; }
    :global(.history-kebab) {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 2rem;
      height: 2rem;
      padding: 0;
      border: 1px solid var(--border);
      border-radius: 999px;
      background: rgba(255, 255, 255, .04);
      color: var(--text);
      cursor: pointer;
      font-size: 1.35rem;
      font-weight: 700;
      line-height: 1;
      letter-spacing: .08em;
    }
    :global(.history-kebab:hover),
    :global(.history-kebab:focus-visible) {
      background: var(--surface);
      outline: none;
    }
    :global(.history-actions-menu) {
      position: absolute;
      right: 0;
      top: calc(100% + .45rem);
      min-width: 220px;
      padding: .45rem;
      border: 1px solid rgba(148, 163, 184, .28);
      border-radius: 14px;
      background: #111827;
      box-shadow: 0 24px 70px rgba(0, 0, 0, .55);
      z-index: 200;
    }
    :global(.history-actions-menu.hidden) { display: none; }
    :global(.history-actions-menu button),
    :global(.history-actions-menu a) {
      display: flex;
      align-items: center;
      width: 100%;
      min-height: 2.45rem;
      padding: .6rem .75rem;
      border: 0;
      border-radius: 10px;
      background: transparent;
      color: #f8fafc;
      text-align: left;
      text-decoration: none;
      font: inherit;
      font-size: .88rem;
      cursor: pointer;
      white-space: nowrap;
    }
    :global(.history-actions-menu button:hover),
    :global(.history-actions-menu a:hover) { background: rgba(255, 255, 255, .08); }
    :global(.history-actions-menu .danger) { color: #fca5a5; }
    .history-modal.hidden,
    :global(.history-modal.hidden) { display: none; }
    .history-modal {
      position: fixed;
      inset: 0;
      z-index: 10000;
      display: grid;
      place-items: center;
      padding: 1rem;
    }
    .history-modal-backdrop {
      position: absolute;
      inset: 0;
      background: rgba(2, 6, 23, .86);
      backdrop-filter: blur(6px);
    }
    .history-modal-panel {
      position: relative;
      width: min(560px, calc(100vw - 2rem));
      max-height: min(720px, calc(100vh - 2rem));
      overflow: auto;
      padding: 1.35rem;
      border-radius: 18px;
      border: 1px solid rgba(148, 163, 184, .24);
      background: #111827;
      color: #f8fafc;
      box-shadow: 0 24px 80px rgba(0, 0, 0, .6);
    }
    .history-modal-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 1rem;
    }
    .history-modal-header h2 { margin: 0; }
    .history-modal-close {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 2rem;
      padding: .4rem .75rem;
      border: 1px solid rgba(148, 163, 184, .28);
      border-radius: 999px;
      background: rgba(255, 255, 255, .06);
      color: #f8fafc;
      cursor: pointer;
      font: inherit;
      font-size: .85rem;
      font-weight: 600;
      line-height: 1;
    }
    .history-modal-close:hover { background: rgba(255, 255, 255, .1); }
  </style>

  <script define:vars={{ cleanupDeletesUnassigned }}>
    window.currentAdminUpdateState = null;

    function toast(msg, ok) {
      const el = document.getElementById("toast");
      if (!el) return;
      el.textContent = msg;
      el.className = ok ? "toast-ok" : "toast-err";
      el.style.display = "block";
      setTimeout(() => (el.style.display = "none"), 5000);
    }

    async function api(path, opts) {
      const res = await fetch(path, opts);
      const text = await res.text();
      try {
        return JSON.parse(text);
      } catch {
        return { ok: false, error: text || "Bad response (" + res.status + ")" };
      }
    }

    document.getElementById("logoutBtn")?.addEventListener("click", async () => {
      await fetch("/api/auth/logout", { method: "POST" });
      window.location.href = "/login";
    });

    document.addEventListener("click", async (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;

      const menuButton = target.closest("[data-history-menu]");
      if (menuButton instanceof HTMLElement) {
        const index = menuButton.getAttribute("data-history-menu");
        const menu = index ? document.getElementById("historyMenu" + index) : null;
        const willOpen = menu?.classList.contains("hidden");
        closeHistoryMenus();
        if (menu && willOpen) menu.classList.remove("hidden");
        return;
      }

      const changelogButton = target.closest("[data-history-changelog]");
      if (changelogButton instanceof HTMLElement) {
        const row = latestHistoryRows[Number(changelogButton.getAttribute("data-history-changelog"))];
        closeHistoryMenus();
        if (row) showChangelog(row);
        return;
      }

      const restoreButton = target.closest("[data-history-restore]");
      if (restoreButton instanceof HTMLElement) {
        const row = latestHistoryRows[Number(restoreButton.getAttribute("data-history-restore"))];
        closeHistoryMenus();
        if (row) showRestoreWarning(row);
        return;
      }

      const confirmRestoreButton = target.closest("[data-confirm-history-restore]");
      if (confirmRestoreButton instanceof HTMLElement) {
        const deployId = confirmRestoreButton.getAttribute("data-confirm-history-restore");
        if (deployId) {
          confirmRestoreButton.setAttribute("disabled", "true");
          confirmRestoreButton.textContent = "Restoring...";
          await restoreHistoryBuild(deployId);
        }
        return;
      }

      if (target.closest("[data-history-modal-close]")) {
        closeHistoryModal();
        return;
      }

      if (!target.closest(".history-actions")) closeHistoryMenus();
    });

    let latestHistoryRows = [];

    function escapeHtml(value) {
      return String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");
    }

    function escapeAttr(value) {
      return escapeHtml(value).replaceAll("`", "&#096;");
    }

    function formatHistoryDate(value) {
      if (!value) return "—";
      const d = new Date(value);
      if (Number.isNaN(d.getTime())) return "—";
      return d.toLocaleString();
    }

    function renderUpdateHistory(rows) {
      const area = document.getElementById("historyArea");
      if (!area) return;

      if (!rows || rows.length === 0) {
        area.innerHTML = '<p class="text-sm text-muted" style="margin:0;">No update history yet.</p>';
        return;
      }

      latestHistoryRows = rows;
      const htmlRows = rows
        .map((row, index) => {
          const commit = row.commitRef ? String(row.commitRef).slice(0, 7) : "—";
          const version = row.version || "—";
          const state = row.status === "live"
            ? '<span class="history-badge-live">Live</span>'
            : "Previous";
          const restoreNote = row.republished
            ? '<div class="text-xs text-muted" style="margin-top:.25rem;">Restored/republished from build created ' + escapeHtml(formatHistoryDate(row.originalDeployDate)) + "</div>"
            : "";
          const branch = row.branch || "—";
          const previewAction = row.deployUrl
            ? '<a href="' + escapeAttr(row.deployUrl) + '" target="_blank" rel="noopener noreferrer">Open build preview</a>'
            : "";
          const restoreAction = row.status === "live"
            ? ""
            : '<button type="button" class="danger" data-history-restore="' + index + '">Restore this build</button>';
          return (
            "<tr>" +
            "<td>" + escapeHtml(formatHistoryDate(row.date)) + restoreNote + "</td>" +
            "<td>" + escapeHtml(version) + "</td>" +
            "<td>" + state + "</td>" +
            "<td class=\"mono\">" + escapeHtml(commit) + "</td>" +
            "<td>" + escapeHtml(branch) + "</td>" +
            '<td><div class="history-actions">' +
            '<button type="button" class="history-kebab" data-history-menu="' + index + '" aria-label="Open row actions" title="More actions">...</button>' +
            '<div class="history-actions-menu hidden" id="historyMenu' + index + '">' +
            previewAction +
            '<button type="button" data-history-changelog="' + index + '">Changelog</button>' +
            restoreAction +
            "</div></div></td>" +
            "</tr>"
          );
        })
        .join("");

      area.innerHTML =
        "<table class=\"history-table\">" +
        "<thead><tr><th>Date</th><th>Version</th><th>Status</th><th>Commit</th><th>Branch</th><th><span class=\"sr-only\">Actions</span></th></tr></thead>" +
        "<tbody>" +
        htmlRows +
        "</tbody>" +
        "</table>";
    }

    function closeHistoryMenus() {
      document.querySelectorAll(".history-actions-menu").forEach((menu) => menu.classList.add("hidden"));
    }

    function closeHistoryModal() {
      const modal = document.getElementById("historyModal");
      if (modal) modal.classList.add("hidden");
      const body = document.getElementById("historyModalBody");
      if (body) body.innerHTML = "";
      const actions = document.getElementById("historyModalActions");
      if (actions) {
        actions.classList.add("hidden");
        actions.innerHTML = "";
      }
    }

    function showHistoryModal(title, bodyHtml, actionsHtml) {
      const modal = document.getElementById("historyModal");
      const modalTitle = document.getElementById("historyModalTitle");
      const body = document.getElementById("historyModalBody");
      const actions = document.getElementById("historyModalActions");
      if (!modal || !modalTitle || !body || !actions) return;
      modalTitle.textContent = title;
      body.innerHTML = bodyHtml;
      actions.innerHTML = actionsHtml || "";
      actions.classList.toggle("hidden", !actionsHtml);
      modal.classList.remove("hidden");
    }

    function showChangelog(row) {
      const items = Array.isArray(row.changelog) && row.changelog.length > 0
        ? row.changelog
        : ["This build updated the builder code."];
      const details = [
        '<p style="margin-top:0;color:var(--text);font-weight:600;">What changed in this build?</p>',
        '<ul style="margin:.5rem 0 1rem;padding-left:1.25rem;">' + items.map((item) => '<li style="margin:.35rem 0;">' + escapeHtml(item) + "</li>").join("") + "</ul>",
        '<p class="text-xs text-muted" style="margin-bottom:0;">Build: <span class="mono">' + escapeHtml(row.commitRef ? String(row.commitRef).slice(0, 7) : row.id) + "</span></p>",
      ].join("");
      showHistoryModal("Changelog", details, "");
    }

    function showRestoreWarning(row) {
      const buildLabel = row.commitRef ? String(row.commitRef).slice(0, 7) : row.id;
      const body = [
        '<p style="margin-top:0;color:var(--danger);font-weight:600;">You are about to restore a previous builder build.</p>',
        "<p>This will switch the live MasjidWeb builder to the selected build. Tenant sites may start serving this version shortly after confirmation.</p>",
        '<p><strong>Selected build:</strong> <span class="mono">' + escapeHtml(buildLabel) + "</span></p>",
        "<p><strong>Published:</strong> " + escapeHtml(formatHistoryDate(row.date)) + "</p>",
        "<p>Please only continue if the latest build is broken or you intentionally want to roll back.</p>",
      ].join("");
      const actions =
        '<button type="button" class="btn btn-ghost" data-history-modal-close>Cancel</button>' +
        '<button type="button" class="btn btn-primary" data-confirm-history-restore="' + escapeAttr(row.id) + '">Yes, restore this build</button>';
      showHistoryModal("Restore previous build?", body, actions);
    }

    async function restoreHistoryBuild(deployId) {
      const data = await api("/api/updates/rollback", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ deployId }),
      });
      if (data.ok) {
        toast(data.message || "Build restored.", true);
        closeHistoryModal();
        await runUpdateCheck();
      } else {
        toast(data.error || data.message || "Could not restore build", false);
      }
    }

    const PREVIEW_TENANT_STORAGE_KEY = "mw_core_update_preview_tenant_slug";
    const DEFAULT_PREVIEW_TENANT_SLUG = "masjidemo1";

    function getStoredPreviewTenantSlug() {
      try {
        const value = localStorage.getItem(PREVIEW_TENANT_STORAGE_KEY);
        return value && String(value).trim() ? String(value).trim() : DEFAULT_PREVIEW_TENANT_SLUG;
      } catch {
        return DEFAULT_PREVIEW_TENANT_SLUG;
      }
    }

    function setStoredPreviewTenantSlug(slug) {
      try {
        if (slug) localStorage.setItem(PREVIEW_TENANT_STORAGE_KEY, slug);
      } catch {
        /* ignore */
      }
    }

    function previewTenantOptionLabel(option) {
      if (!option) return "";
      if (option.slug === DEFAULT_PREVIEW_TENANT_SLUG) return "MasjidDemo1 (template)";
      const name = option.businessName ? String(option.businessName).trim() : "";
      return name ? name + " (" + option.slug + ")" : option.slug;
    }

    function getCurrentUpdatePhase(phases) {
      if (!Array.isArray(phases)) return null;
      return phases.find((phase) => phase.status === "current") || null;
    }

    function getPhaseByStep(phases, step) {
      if (!Array.isArray(phases)) return null;
      return phases.find((phase) => phase.step === step) || null;
    }

    function getWorkflowStep(phases) {
      const current = getCurrentUpdatePhase(phases);
      return current && current.step ? current.step : 1;
    }

    const CORE_UPDATE_STEP_COUNT = 4;
    const CORE_UPDATE_VIEWED_STEP_KEY = "mw_core_update_viewed_step";
    const CORE_UPDATE_LAST_WORKFLOW_KEY = "mw_core_update_last_workflow_step";
    const CORE_UPDATE_STEPPER_LABELS = ["Prepare", "Fix", "Preview", "Approve"];

    function getStoredViewedStep() {
      const n = parseInt(sessionStorage.getItem(CORE_UPDATE_VIEWED_STEP_KEY) || "", 10);
      return n >= 1 && n <= CORE_UPDATE_STEP_COUNT ? n : null;
    }

    function setStoredViewedStep(step) {
      sessionStorage.setItem(CORE_UPDATE_VIEWED_STEP_KEY, String(step));
    }

    function resolveViewedStep(adminState) {
      const workflowStep = getWorkflowStep(adminState.phases || []);
      let lastWorkflow = parseInt(sessionStorage.getItem(CORE_UPDATE_LAST_WORKFLOW_KEY) || "", 10);
      sessionStorage.setItem(CORE_UPDATE_LAST_WORKFLOW_KEY, String(workflowStep));
      if (!Number.isNaN(lastWorkflow) && workflowStep > lastWorkflow) {
        setStoredViewedStep(workflowStep);
        return workflowStep;
      }
      const stored = getStoredViewedStep();
      return stored || workflowStep;
    }

    function shouldShowPreviewBlock(adminState, viewedStep) {
      if (!adminState || viewedStep !== 3) return false;
      if ((adminState.canPreview || adminState.canApprove) && adminState.preview) return true;
      const phase = getPhaseByStep(adminState.phases, 3);
      return Boolean(phase && (phase.status === "current" || phase.status === "done"));
    }

    function renderPreviewTenantPickerHtml(options, selectedSlug) {
      const list = Array.isArray(options) ? options : [];
      if (list.length === 0) return "";
      const current = selectedSlug || getStoredPreviewTenantSlug();
      const optionsHtml = list
        .map((option) => {
          const slug = String(option.slug || "");
          const selected = slug === current ? " selected" : "";
          return (
            '<option value="' +
            escapeAttr(slug) +
            '"' +
            selected +
            ">" +
            escapeHtml(previewTenantOptionLabel(option)) +
            "</option>"
          );
        })
        .join("");
      return (
        '<div class="core-update-preview-picker">' +
        '<label for="previewTenantSelect" class="text-xs text-muted" style="display:block;margin-bottom:.35rem;font-weight:600;">Preview as</label>' +
        '<select id="previewTenantSelect" class="preview-tenant-select">' +
        optionsHtml +
        "</select></div>"
      );
    }

    function renderStepper(phases, viewedStep) {
      const list = Array.isArray(phases) ? phases : [];
      const items = [];
      for (let step = 1; step <= CORE_UPDATE_STEP_COUNT; step += 1) {
        const phase = getPhaseByStep(list, step) || { step, status: "upcoming" };
        const shortLabel = CORE_UPDATE_STEPPER_LABELS[step - 1] || String(step);
        const classes = ["core-update-stepper-btn", phase.status];
        if (step === viewedStep) classes.push("viewing");
        const dot =
          phase.status === "done"
            ? "\u2713"
            : phase.status === "skipped"
              ? "\u2014"
              : String(step);
        items.push(
          '<li class="core-update-stepper-item">' +
            '<button type="button" class="' +
            classes.join(" ") +
            '" data-goto-step="' +
            escapeAttr(step) +
            '" aria-current="' +
            (step === viewedStep ? "step" : "false") +
            '">' +
            '<span class="core-update-stepper-dot">' +
            escapeHtml(dot) +
            "</span>" +
            '<span class="core-update-stepper-label">' +
            escapeHtml(shortLabel) +
            "</span>" +
            "</button></li>",
        );
      }
      return (
        '<nav aria-label="Core update steps"><ol class="core-update-stepper">' + items.join("") + "</ol></nav>"
      );
    }

    function renderStepBadge(phase, viewedStep, workflowStep) {
      if (viewedStep === workflowStep) {
        return '<span class="core-update-step-badge live">You are here</span>';
      }
      if (phase.status === "done") {
        return '<span class="core-update-step-badge done">Completed</span>';
      }
      if (phase.status === "skipped") {
        return '<span class="core-update-step-badge skipped">Skipped</span>';
      }
      return '<span class="core-update-step-badge upcoming">Up next</span>';
    }

    function renderStepPanel(adminState, data, viewedStep) {
      const phases = adminState.phases || [];
      const phase = getPhaseByStep(phases, viewedStep);
      const workflowStep = getWorkflowStep(phases);
      if (!phase) return "";

      const isLiveStep = viewedStep === workflowStep;
      let headline = phase.title;
      let guide = phase.detail;
      if (isLiveStep) {
        if (adminState.title) headline = adminState.title;
        if (adminState.nextActionText) guide = adminState.nextActionText;
      } else if (phase.status === "skipped" && viewedStep === 2) {
        guide = "No merge conflicts were detected for this update. You can move on to preview when the pull request is ready.";
      }

      let html = '<div class="core-update-step-panel">';
      html += renderStepBadge(phase, viewedStep, workflowStep);
      html += '<h3 class="core-update-headline">' + escapeHtml(headline) + "</h3>";
      html += '<p class="core-update-guide">' + escapeHtml(guide) + "</p>";

      if (shouldShowPreviewBlock(adminState, viewedStep)) {
        const selectedSlug = (data && data.previewTenant && data.previewTenant.slug) || getStoredPreviewTenantSlug();
        const preview = adminState.preview;
        html += '<div class="core-update-preview-panel">';
        html += renderPreviewTenantPickerHtml(data && data.previewTenantOptions, selectedSlug);
        if (preview) {
          html +=
            '<div class="core-update-preview-warn">Live sites still use <span class="mono">' +
            escapeHtml(preview.productionBuilderUrl) +
            "</span>. Use Open builder preview for PR code.</div>";
          html +=
            '<p class="text-xs text-muted" style="margin:.55rem 0 0;">Sign in on the preview as <span class="mono">' +
            escapeHtml(preview.loginEmailHint) +
            "</span></p>";
        }
        html += "</div>";
      }

      html += "</div>";
      return html;
    }

    function renderWizardNav(viewedStep, workflowStep) {
      const backDisabled = viewedStep <= 1;
      const nextDisabled = viewedStep >= CORE_UPDATE_STEP_COUNT;
      let center =
        '<span class="text-xs text-muted" style="align-self:center;">Step ' +
        escapeHtml(viewedStep) +
        " of " +
        escapeHtml(CORE_UPDATE_STEP_COUNT) +
        "</span>";
      if (viewedStep !== workflowStep) {
        center =
          '<button type="button" class="btn btn-ghost btn-sm" data-goto-step="' +
          escapeAttr(workflowStep) +
          '">Jump to current</button>';
      }
      return (
        '<div class="core-update-wizard-nav">' +
        '<button type="button" id="coreUpdateStepBack" class="btn btn-ghost btn-sm"' +
        (backDisabled ? " disabled" : "") +
        ">\u2190 Back</button>" +
        center +
        '<button type="button" id="coreUpdateStepNext" class="btn btn-ghost btn-sm"' +
        (nextDisabled ? " disabled" : "") +
        ">Next \u2192</button></div>"
      );
    }

    function buildVersionLine(data) {
      if (!data || data.ok !== true) return "";
      const latest = data.latestReleaseVersion;
      const live = data.deployedPackageVersion || data.forkPackageVersion;
      if (!latest && !live) return "";
      let line = "Release " + (latest || "—") + " · Live builder " + (live || "—");
      if (data.deployCommitRef && data.deployedPackageVersion) {
        line += " · commit " + String(data.deployCommitRef).slice(0, 7);
      }
      return line;
    }

    function renderCoreUpdateWizard(adminState, data, viewedStep) {
      const phases = adminState.phases || [];
      const step = Math.max(1, Math.min(CORE_UPDATE_STEP_COUNT, viewedStep || resolveViewedStep(adminState)));
      const productionPillClass = adminState.productionStatus === "Deploy pending" ? " pending" : "";
      const versionLine = buildVersionLine(data);

      let html = '<div class="core-update-state" data-viewed-step="' + escapeAttr(step) + '">';
      html +=
        '<div class="core-update-topline"><span class="core-update-pill' +
        productionPillClass +
        '">' +
        escapeHtml(adminState.productionStatus || "Production unchanged") +
        "</span></div>";

      if (phases.length > 0) {
        html += renderStepper(phases, step);
        html += renderStepPanel(adminState, data, step);
        html += renderWizardNav(step, getWorkflowStep(phases));
      } else {
        html += '<h3 class="core-update-headline">' + escapeHtml(adminState.title) + "</h3>";
        html += '<p class="core-update-guide">' + escapeHtml(adminState.description) + "</p>";
      }

      if (versionLine) {
        html += '<p class="core-update-version text-xs text-muted">' + escapeHtml(versionLine) + "</p>";
      }

      html += "</div>";
      return html;
    }

    function refreshCoreUpdateView(nextStep) {
      const adminState = window.currentAdminUpdateState;
      const data = window.currentUpdateCheckData;
      const statusArea = document.getElementById("statusArea");
      if (!adminState || !statusArea) return;

      let viewed = nextStep;
      if (viewed == null) {
        viewed = resolveViewedStep(adminState);
      } else {
        viewed = Math.max(1, Math.min(CORE_UPDATE_STEP_COUNT, viewed));
        setStoredViewedStep(viewed);
      }
      window.coreUpdateViewedStep = viewed;
      statusArea.innerHTML = renderCoreUpdateWizard(adminState, data, viewed);
    }

    async function runUpdateCheck() {
      const btn = document.getElementById("checkUpdatesBtn");
      if (btn) {
        btn.disabled = true;
        btn.innerHTML = '<span style="opacity:.6">Checking...</span>';
      }

      const previewSlug = getStoredPreviewTenantSlug();
      const statusUrl =
        "/api/updates/status?previewTenantSlug=" + encodeURIComponent(previewSlug);
      const data = await api(statusUrl);
      if (btn) {
        btn.disabled = false;
        btn.innerHTML = '<svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg> Refresh status';
      }

      const statusArea = document.getElementById("statusArea");
      if (!statusArea) return;

      const adminState = data.adminState || {
        status: data.ok === true && data.releaseAheadOfForkPackage ? "update_available" : data.ok === true ? "up_to_date" : "unknown_error",
        title: data.ok === true && data.releaseAheadOfForkPackage ? "Update available" : data.ok === true ? "Up to date" : "Update status unavailable",
        description: data.ok === true && data.releaseAheadOfForkPackage
          ? "A safe Ycode update can be prepared. Production will not change immediately."
          : data.ok === true
            ? "No action needed. Production is already on the latest known safe version."
            : "The admin dashboard could not read update status. Do not approve anything yet. Production is unchanged.",
        productionStatus: "Production unchanged",
        actionLabel: "Prepare safe update",
        nextActionText: "Refresh status or ask AI/operator to inspect the update dashboard.",
        agentPrompt: null,
        canPrepare: data.ok === true && data.releaseAheadOfForkPackage === true,
        canApprove: false,
        prUrl: null,
      };
      const applyButton = document.getElementById("applyBuilderUpdateBtn");
      const safeUpdatePrLink = document.getElementById("safeUpdatePrLink");
      const openPreviewBtn = document.getElementById("openPreviewBtn");
      const primaryEnabled =
        adminState.canPrepare ||
        adminState.status === "preparing" ||
        adminState.canCopyPrompt ||
        adminState.canPreview ||
        adminState.canApprove;
      if (applyButton) {
        applyButton.textContent = adminState.actionLabel;
        applyButton.disabled = !primaryEnabled;
      }
      if (safeUpdatePrLink) {
        if (adminState.prUrl) {
          safeUpdatePrLink.setAttribute("href", adminState.prUrl);
          safeUpdatePrLink.classList.remove("hidden");
        } else {
          safeUpdatePrLink.classList.add("hidden");
        }
      }
      if (openPreviewBtn) {
        const previewHref = adminState.previewBuilderUrl || adminState.previewUrl;
        if (adminState.canPreview && previewHref) {
          openPreviewBtn.setAttribute("href", previewHref);
          const label = adminState.preview?.tenantLabel || "tenant";
          openPreviewBtn.textContent = "Open " + label + " builder preview";
          openPreviewBtn.classList.remove("hidden");
        } else {
          openPreviewBtn.classList.add("hidden");
        }
      }

      const selectedPreviewSlug = data.previewTenant?.slug || previewSlug;
      if (selectedPreviewSlug) setStoredPreviewTenantSlug(selectedPreviewSlug);

      window.currentAdminUpdateState = adminState;
      window.currentUpdateCheckData = data;
      refreshCoreUpdateView();

      if (data.ok !== true) {
        toast(adminState.description, false);
        renderUpdateHistory([]);
        return;
      }

      renderUpdateHistory(Array.isArray(data.updateHistory) ? data.updateHistory : []);
    }

    function setApplyUpdateResult(message, ok, opts = {}) {
      const el = document.getElementById("applyUpdateResult");
      if (!el) return;

      const lines = [];
      if (opts.requiresTechAction === true) {
        lines.push(opts.adminMessage ? String(opts.adminMessage) : "Update paused for technical review.");
        lines.push("No action needed from platform admin.");
      } else if (opts.prUrl) {
        const label = opts.prNumber ? "Open conflict PR #" + opts.prNumber : "Open conflict PR";
        lines.push("Update paused: one merge conflict needs a one-time fix.");
        lines.push("Step 1: Open the conflict PR.");
        lines.push('<a href="' + String(opts.prUrl) + '" target="_blank" rel="noopener noreferrer">' + label + "</a>");
        lines.push("Step 2: Resolve conflicts and merge that PR on GitHub.");
        lines.push("Step 3: Return here and click Apply YCode update again.");
      } else {
        if (message) lines.push(String(message));
        if (opts.hint) lines.push(String(opts.hint));
      }

      if (opts.compareUrl && !opts.prUrl) {
        lines.push('<a href="' + String(opts.compareUrl) + '" target="_blank" rel="noopener noreferrer">Open compare view</a>');
      }

      el.innerHTML = lines.join("<br />");
      el.classList.remove("hidden");
      if (ok) {
        el.style.background = "var(--success-bg)";
        el.style.borderColor = "rgba(34,197,94,.2)";
        el.style.color = "var(--success)";
      } else {
        el.style.background = "rgba(239,68,68,.1)";
        el.style.borderColor = "rgba(239,68,68,.35)";
        el.style.color = "var(--danger)";
      }
    }

    async function postPrepareSafeUpdate() {
      const data = await api("/api/updates/prepare-safe-update", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
      });

      if (data.ok === true) {
        setApplyUpdateResult(data.message || "Safe update preparation has started. Production has not changed.", true);
        toast(data.message || "Safe update preparation has started.", true);
        setTimeout(runUpdateCheck, 3000);
        return;
      }

      const msg = typeof data.message === "string"
        ? data.message
        : typeof data.error === "string"
          ? data.error
          : "Could not prepare safe update";
      setApplyUpdateResult(msg, false);
      toast(msg, false);
    }

    document.getElementById("checkUpdatesBtn")?.addEventListener("click", runUpdateCheck);

    document.getElementById("statusArea")?.addEventListener("change", async (event) => {
      const target = event.target;
      if (!(target instanceof HTMLSelectElement) || target.id !== "previewTenantSelect") return;
      const slug = target.value?.trim();
      if (!slug) return;
      setStoredPreviewTenantSlug(slug);
      await runUpdateCheck();
    });

    document.getElementById("statusArea")?.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;

      const gotoBtn = target.closest("[data-goto-step]");
      if (gotoBtn instanceof HTMLElement && gotoBtn.dataset.gotoStep) {
        refreshCoreUpdateView(parseInt(gotoBtn.dataset.gotoStep, 10));
        return;
      }

      if (target.id === "coreUpdateStepBack" || target.closest("#coreUpdateStepBack")) {
        refreshCoreUpdateView((window.coreUpdateViewedStep || 1) - 1);
        return;
      }

      if (target.id === "coreUpdateStepNext" || target.closest("#coreUpdateStepNext")) {
        refreshCoreUpdateView((window.coreUpdateViewedStep || 1) + 1);
      }
    });

    const applyBuilderBtn = document.getElementById("applyBuilderUpdateBtn");
    applyBuilderBtn?.addEventListener("click", async () => {
      const state = window.currentAdminUpdateState || {};

      if (state.status === "preparing") {
        await runUpdateCheck();
        return;
      }

      if (state.status === "blocked_needs_resolution" || state.status === "checks_failed") {
        const prompt = state.agentPrompt || state.nextActionText || "Resolve the MasjidWeb safe core update.";
        try {
          await navigator.clipboard.writeText(prompt);
          toast("Copied AI repair prompt. Paste it into Cursor or your AI agent.", true);
        } catch {
          setApplyUpdateResult("Copy this AI repair prompt and paste it into Cursor or your AI agent:<br /><br />" + escapeHtml(prompt).replaceAll("\n", "<br />"), true);
        }
        return;
      }

      if ((state.status === "ready_to_approve" || state.status === "ready_to_preview") && state.canApprove) {
        const prLabel = state.prNumber ? "PR #" + state.prNumber : "the safe update pull request";
        if (
          !confirm(
            "Approve and merge " +
              prLabel +
              " now? Production will deploy the new core after the merge build finishes.",
          )
        ) {
          return;
        }
        applyBuilderBtn.disabled = true;
        applyBuilderBtn.textContent = "Approving…";
        const res = await api("/api/updates/approve-safe-update", { method: "POST" });
        applyBuilderBtn.disabled = false;
        if (res.ok) {
          setApplyUpdateResult(res.message || "Update approved.", true);
          toast(res.message || "Update approved.", true);
          setTimeout(runUpdateCheck, 2500);
        } else {
          const err = res.error || res.message || "Could not approve update";
          setApplyUpdateResult(err, false);
          toast(err, false);
        }
        await runUpdateCheck();
        return;
      }

      if (!state.canPrepare) {
        await runUpdateCheck();
        return;
      }

      if (!confirm("Prepare a safe Ycode update now? Production will not change immediately.")) return;
      applyBuilderBtn.disabled = true;
      applyBuilderBtn.textContent = "Preparing…";
      await postPrepareSafeUpdate();
      applyBuilderBtn.disabled = false;
      await runUpdateCheck();
    });

    const restorePrevBtn = document.getElementById("restorePreviousDeployBtn");
    restorePrevBtn?.addEventListener("click", async () => {
      if (!confirm("Restore previous live build now? This changes the live tenant builder immediately.")) return;
      restorePrevBtn.disabled = true;
      restorePrevBtn.textContent = "Restoring…";
      const res = await api("/api/updates/rollback-previous", { method: "POST" });
      if (res.ok) {
        setApplyUpdateResult(res.message || "Restored previous deploy.", true);
        toast(res.message || "Restored previous deploy.", true);
        setTimeout(runUpdateCheck, 2000);
      } else {
        toast(res.error || res.message || "Could not restore", false);
      }
      restorePrevBtn.disabled = false;
      restorePrevBtn.textContent = "Restore previous live build";
    });

    const cleanupOrphansBtn = document.getElementById("cleanupOrphansBtn");
    const rowCleanupResult = document.getElementById("rowCleanupResult");
    cleanupOrphansBtn?.addEventListener("click", async () => {
      const msg =
        "Remove CMS/YCode rows whose tenant_id no longer exists in tenant_registry, align Auth users (delete orphans / repair missing tenant_id from slug), and remove stale builder invites?" +
        (cleanupDeletesUnassigned
          ? " This server is also configured to DELETE Auth users with no tenant_id and no tenant_slug (except emails listed in AUTH_CLEANUP_PRESERVE_AUTH_EMAILS)."
          : "");
      if (!confirm(msg)) return;
      cleanupOrphansBtn.disabled = true;
      if (rowCleanupResult) rowCleanupResult.textContent = "Running database cleanup...";
      try {
        const res = await fetch("/api/cleanup-orphans", { method: "POST" });
        const data = await res.json();
        if (data.ok) {
          const rows = data.removed && data.removed.length
            ? data.removed.map((r) => r.table_name + ": " + r.removed).join(", ")
            : "none";
          const removed = typeof data.authUsersRemoved === "number" && data.authUsersRemoved > 0
            ? "; auth removed: " + data.authUsersRemoved
            : "";
          const repaired = typeof data.authUsersRepaired === "number" && data.authUsersRepaired > 0
            ? "; auth repaired: " + data.authUsersRepaired
            : "";
          const unassigned = typeof data.authUsersRemovedUnassigned === "number" && data.authUsersRemovedUnassigned > 0
            ? "; no-tenant auth removed: " + data.authUsersRemovedUnassigned
            : "";
          const summary = "Cleanup done: " + rows + removed + repaired + unassigned;
          if (rowCleanupResult) rowCleanupResult.textContent = summary;
          toast(summary, true);
        } else {
          if (rowCleanupResult) rowCleanupResult.textContent = data.error || "Cleanup failed";
          toast(data.error || "Cleanup failed", false);
        }
      } catch (err) {
        const message = err.message || "Cleanup failed";
        if (rowCleanupResult) rowCleanupResult.textContent = message;
        toast(message, false);
      } finally {
        cleanupOrphansBtn.disabled = false;
      }
    });

    runUpdateCheck();

    const cleanupDomainAliasesBtn = document.getElementById("cleanupDomainAliasesBtn");
    const domainCleanupResult = document.getElementById("domainCleanupResult");
    cleanupDomainAliasesBtn?.addEventListener("click", async () => {
      cleanupDomainAliasesBtn.disabled = true;
      if (domainCleanupResult) domainCleanupResult.textContent = "Checking for orphan subdomains...";
      try {
        const previewRes = await fetch("/api/cleanup-domain-aliases");
        const preview = await previewRes.json();
        if (!preview.ok) {
          if (domainCleanupResult) domainCleanupResult.textContent = preview.error || "Subdomain preview failed";
          toast(preview.error || "Subdomain preview failed", false);
          return;
        }

        const aliases = Array.isArray(preview.orphanAliases) ? preview.orphanAliases : [];
        if (aliases.length === 0) {
          if (domainCleanupResult) domainCleanupResult.textContent = "No orphan subdomains found.";
          toast("No orphan subdomains found", true);
          return;
        }

        const list = aliases.slice(0, 20).join("\n");
        const more = aliases.length > 20 ? "\n...and " + (aliases.length - 20) + " more" : "";
        if (!confirm("Remove these orphan Netlify tenant subdomains?\n\n" + list + more)) {
          if (domainCleanupResult) domainCleanupResult.textContent = "Cleanup cancelled. Found " + aliases.length + " orphan subdomain(s).";
          return;
        }

        if (domainCleanupResult) domainCleanupResult.textContent = "Removing " + aliases.length + " orphan subdomain(s)...";
        const cleanupRes = await fetch("/api/cleanup-domain-aliases", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ aliases }),
        });
        const cleanup = await cleanupRes.json();
        if (cleanup.ok) {
          const removedAliases = Array.isArray(cleanup.removed) ? cleanup.removed : [];
          const skippedAliases = Array.isArray(cleanup.skipped) ? cleanup.skipped : [];
          const skipped = skippedAliases.length ? "; skipped: " + skippedAliases.length : "";
          const summary = "Subdomain cleanup done: removed " + removedAliases.length + skipped;
          if (domainCleanupResult) domainCleanupResult.textContent = summary;
          toast(summary, true);
        } else {
          if (domainCleanupResult) domainCleanupResult.textContent = cleanup.error || "Subdomain cleanup failed";
          toast(cleanup.error || "Subdomain cleanup failed", false);
        }
      } catch (err) {
        const message = err.message || "Subdomain cleanup failed";
        if (domainCleanupResult) domainCleanupResult.textContent = message;
        toast(message, false);
      } finally {
        cleanupDomainAliasesBtn.disabled = false;
      }
    });
  </script>
</Layout>
