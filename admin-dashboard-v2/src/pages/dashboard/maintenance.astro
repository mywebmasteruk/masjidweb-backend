---
import Layout from "../../layouts/Layout.astro";
import SidebarBrand from "../../components/SidebarBrand.astro";

const cleanupDeletesUnassigned =
  import.meta.env.AUTH_CLEANUP_DELETE_UNASSIGNED === "true" ||
  import.meta.env.AUTH_CLEANUP_DELETE_UNASSIGNED === "1" ||
  String(import.meta.env.AUTH_CLEANUP_DELETE_UNASSIGNED ?? "").toLowerCase() === "yes";
---

<Layout title="Maintenance — MasjidWeb Admin">
  <div class="shell">
    <aside class="sidebar">
      <SidebarBrand />
      <nav class="sidebar-nav">
        <a href="/dashboard" class="sidebar-link">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
          Tenants
        </a>
        <a href="/dashboard/logs" class="sidebar-link">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          Logs
        </a>
        <a href="/dashboard/maintenance" class="sidebar-link active">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          Maintenance
        </a>
        <a href="/dashboard/settings/ai" class="sidebar-link">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6V4m0 16v-2m8-6h-2M6 12H4m13.657-5.657l-1.414 1.414M7.757 16.243l-1.414 1.414m0-11.314l1.414 1.414m8.486 8.486l1.414 1.414"/><circle cx="12" cy="12" r="3"/></svg>
          Settings
        </a>
      </nav>
      <div class="sidebar-footer">
        <button id="logoutBtn" class="sidebar-link" style="width:100%;border:none;background:none;cursor:pointer;text-align:left;font-family:inherit;">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
          Log out
        </button>
      </div>
    </aside>

    <main class="main">
      <div style="margin-bottom:1.5rem;">
        <h1>Maintenance</h1>
        <p class="page-desc" style="margin-bottom:0;">Prepare safe platform updates, rollbacks, and cleanup jobs from one place.</p>
      </div>

      <div class="card core-update-card">
        <div class="card-header">
          <div>
            <h2>Core Update</h2>
            <p class="text-xs text-muted" style="margin:.35rem 0 0;">Update the live builder safely. Production stays unchanged until you approve.</p>
          </div>
          <button id="checkUpdatesBtn" class="btn btn-ghost btn-sm">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
            Refresh status
          </button>
        </div>

        <div id="statusArea" style="margin-bottom:1rem;">
          <div class="status-placeholder">
            <p class="text-sm text-muted">Checking safe core update status...</p>
          </div>
        </div>


        <div class="flex core-update-actions" style="flex-wrap:wrap;gap:.75rem;align-items:center;margin-top:1rem;">
          <button type="button" id="applyBuilderUpdateBtn" class="btn btn-primary">Prepare safe update</button>
          <a id="openPreviewBtn" class="btn btn-ghost hidden" href="#" target="_blank" rel="noopener noreferrer">Open MasjidDemo1 homepage preview</a>
          <a id="safeUpdatePrLink" class="btn btn-ghost hidden" href="#" target="_blank" rel="noopener noreferrer">Open pull request</a>
        </div>
        <div id="applyUpdateResult" class="hidden text-xs" style="margin-top:.75rem;padding:.75rem;border-radius:var(--radius);border:1px solid var(--border);"></div>
      </div>

      <div class="card recovery-card">
        <div class="card-header">
          <div>
            <h2>Recovery</h2>
            <p class="text-xs text-muted" style="margin:.35rem 0 0;">Rollback the live builder if an approved update causes trouble. The table shows one production build per <strong>Ycode core version</strong> (routine redeploys of the same version are hidden). Use <strong>Restore as live</strong> in the row menu to switch Netlify only. <strong>Full rollback</strong> also reverts the git merge to the pre-update checkpoint (when recorded).</p>
          </div>
          <div class="flex" style="flex-wrap:wrap;gap:.5rem;">
            <button type="button" id="rollbackFullUpdateBtn" class="btn btn-ghost hidden">Full rollback to pre-update</button>
          </div>
        </div>
        <p id="reversibleCheckpointHint" class="text-xs text-muted hidden" style="margin:.5rem 0 0;line-height:1.5;"></p>
        <div id="historyArea" class="history-wrap">
          <p class="text-sm text-muted" style="margin:0;">Previous live builder builds load with the update check.</p>
        </div>
      </div>

      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1rem;align-items:start;">
        <div class="card">
          <div class="card-header">
            <h2>Database cleanup</h2>
          </div>
          <p class="text-sm text-muted" style="margin-top:-.35rem;line-height:1.6;">
            Removes CMS/YCode rows whose tenant no longer exists, repairs Auth users from their tenant slug where possible, and clears stale builder invites.
          </p>
          {cleanupDeletesUnassigned ? (
            <p class="text-xs" style="padding:.75rem;border-radius:var(--radius);background:rgba(234,179,8,.08);border:1px solid rgba(234,179,8,.28);color:var(--warning);line-height:1.5;">
              This server is configured to also delete Auth users with no tenant_id and no tenant_slug, except preserved emails.
            </p>
          ) : null}
          <button type="button" id="cleanupOrphansBtn" class="btn btn-primary" style="margin-top:.75rem;">
            Cleanup orphan rows
          </button>
          <div id="rowCleanupResult" class="text-xs text-muted" style="margin-top:.75rem;line-height:1.5;"></div>
        </div>

        <div class="card">
          <div class="card-header">
            <h2>Subdomain cleanup</h2>
          </div>
          <p class="text-sm text-muted" style="margin-top:-.35rem;line-height:1.6;">
            Finds Netlify tenant subdomains under the platform domain that no longer have a tenant row, then removes only the confirmed orphan aliases.
          </p>
          <button type="button" id="cleanupDomainAliasesBtn" class="btn btn-primary" style="margin-top:.75rem;">
            Cleanup orphan subdomains
          </button>
          <div id="domainCleanupResult" class="text-xs text-muted" style="margin-top:.75rem;line-height:1.5;"></div>
        </div>
      </div>
    </main>
  </div>

  <div id="historyModal" class="history-modal hidden" role="dialog" aria-modal="true" aria-labelledby="historyModalTitle">
    <div class="history-modal-backdrop" data-history-modal-close></div>
    <div class="history-modal-panel">
      <div class="history-modal-header">
        <h2 id="historyModalTitle">Update details</h2>
        <button type="button" class="history-modal-close" data-history-modal-close>Close</button>
      </div>
      <div id="historyModalBody" class="text-sm text-muted" style="line-height:1.65;"></div>
      <div id="historyModalActions" class="flex hidden" style="gap:.75rem;justify-content:flex-end;margin-top:1rem;"></div>
    </div>
  </div>

  <div id="toast" style="display:none;position:fixed;right:1rem;bottom:1rem;z-index:9999;padding:.9rem 1.1rem;border-radius:var(--radius);box-shadow:var(--shadow-lg);font-size:.9rem;"></div>

  <style>
    .status-placeholder { padding: .75rem 0; }
  </style>
  <!-- Core update wizard HTML is injected client-side; scoped Astro CSS would not apply. -->
  <style is:global>
    .core-update-state {
      padding: 1rem;
      border: 1px solid rgba(148, 163, 184, .22);
      border-radius: var(--radius);
      background: rgba(15, 23, 42, .28);
    }
    .core-update-topline {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: .6rem;
      margin-bottom: .65rem;
    }
    .core-update-pill {
      display: inline-flex;
      align-items: center;
      border-radius: 999px;
      padding: .18rem .55rem;
      font-size: .72rem;
      font-weight: 700;
      border: 1px solid rgba(34, 197, 94, .24);
      background: var(--success-bg);
      color: var(--success);
    }
    .core-update-pill.pending {
      border-color: rgba(234, 179, 8, .32);
      background: rgba(234, 179, 8, .08);
      color: var(--warning);
    }
    .core-update-traffic {
      display: flex;
      align-items: flex-start;
      gap: .75rem;
      margin-bottom: 1rem;
      padding: .85rem 1rem;
      border-radius: calc(var(--radius) - 1px);
      border: 1px solid rgba(148, 163, 184, .28);
      background: rgba(15, 23, 42, .35);
    }
    .core-update-traffic.is-green {
      border-color: rgba(34, 197, 94, .35);
      background: rgba(34, 197, 94, .08);
    }
    .core-update-traffic.is-amber {
      border-color: rgba(234, 179, 8, .35);
      background: rgba(234, 179, 8, .08);
    }
    .core-update-traffic.is-red {
      border-color: rgba(239, 68, 68, .35);
      background: rgba(239, 68, 68, .08);
    }
    .core-update-traffic-dot {
      flex-shrink: 0;
      width: .75rem;
      height: .75rem;
      margin-top: .2rem;
      border-radius: 999px;
      background: currentColor;
    }
    .core-update-traffic.is-green .core-update-traffic-dot { color: var(--success); }
    .core-update-traffic.is-amber .core-update-traffic-dot { color: var(--warning); }
    .core-update-traffic.is-red .core-update-traffic-dot { color: var(--danger, #ef4444); }
    .core-update-traffic-label {
      margin: 0;
      font-size: .95rem;
      font-weight: 650;
      line-height: 1.35;
    }
    .core-update-traffic-hint {
      margin: .25rem 0 0;
      font-size: .78rem;
      line-height: 1.5;
      color: var(--muted);
    }
    .mw-now-action {
      margin-bottom: 1rem;
      padding: 1rem 1.05rem;
      border-radius: calc(var(--radius) - 1px);
      border: 1px solid rgba(59, 130, 246, .35);
      background: linear-gradient(180deg, rgba(59, 130, 246, .12), rgba(59, 130, 246, .04));
    }
    .mw-now-action.is-waiting {
      border-color: rgba(148, 163, 184, .35);
      background: rgba(148, 163, 184, .08);
    }
    .mw-now-action-label {
      margin: 0;
      font-size: .68rem;
      font-weight: 650;
      letter-spacing: .06em;
      text-transform: uppercase;
      color: var(--muted);
    }
    .mw-now-action-headline {
      display: flex;
      align-items: center;
      gap: .5rem;
      margin: .35rem 0 0;
      font-size: 1.08rem;
      font-weight: 650;
      line-height: 1.35;
      color: var(--text);
    }
    .mw-now-action-detail {
      margin: .45rem 0 0;
      font-size: .85rem;
      line-height: 1.55;
      color: var(--muted);
    }
    .mw-now-action-reassurance {
      margin: .55rem 0 0;
      padding: .55rem .65rem;
      border-radius: calc(var(--radius) - 2px);
      border: 1px solid rgba(34, 197, 94, .28);
      background: rgba(34, 197, 94, .08);
      font-size: .78rem;
      line-height: 1.45;
      color: var(--text);
    }
    .mw-now-action-buttons {
      display: flex;
      flex-wrap: wrap;
      gap: .5rem;
      margin-top: .85rem;
      align-items: center;
    }
    .mw-now-spinner {
      width: .95rem;
      height: .95rem;
      border: 2px solid rgba(148, 163, 184, .35);
      border-top-color: var(--accent);
      border-radius: 50%;
      animation: mw-now-spin .75s linear infinite;
      flex-shrink: 0;
    }
    @keyframes mw-now-spin {
      to { transform: rotate(360deg); }
    }
    .mw-stepper {
      margin: 1rem 0 1.35rem;
    }
    .mw-stepper-list {
      display: flex;
      flex-wrap: nowrap;
      align-items: flex-start;
      justify-content: space-between;
      list-style: none;
      margin: 0;
      padding: 0;
      width: 100%;
      gap: 0;
    }
    .mw-stepper-list > li {
      list-style: none;
      margin: 0;
      padding: 0;
    }
    .mw-stepper-step {
      flex: 0 0 auto;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: .55rem;
      min-width: 4.25rem;
      max-width: 6rem;
      text-align: center;
    }
    .mw-stepper-connector {
      flex: 1 1 0;
      display: block;
      align-self: center;
      height: 3px;
      margin: 1.05rem .15rem 0;
      border-radius: 999px;
      background: rgba(148, 163, 184, .22);
      min-width: 1.25rem;
    }
    .mw-stepper-connector.is-filled {
      background: var(--success);
    }
    .mw-stepper-node {
      width: 2.35rem;
      height: 2.35rem;
      border-radius: 999px;
      border: 2px solid rgba(148, 163, 184, .38);
      background: rgba(15, 23, 42, .55);
      color: var(--muted);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: .8rem;
      font-weight: 700;
      line-height: 1;
      cursor: pointer;
      font-family: inherit;
      padding: 0;
      transition: border-color .15s ease, background .15s ease, color .15s ease, box-shadow .15s ease;
    }
    .mw-stepper-node:hover {
      border-color: rgba(148, 163, 184, .55);
      color: var(--text);
    }
    .mw-stepper-step.is-progress .mw-stepper-node,
    .mw-stepper-step.is-complete .mw-stepper-node {
      border-color: var(--success);
      background: var(--success);
      color: #052e16;
    }
    .mw-stepper-step.is-viewing .mw-stepper-node {
      border-color: var(--accent);
      background: var(--accent);
      color: #fff;
      box-shadow: 0 0 0 3px rgba(59, 130, 246, .28);
    }
    .mw-stepper-step.is-viewing.is-progress .mw-stepper-node {
      border-color: var(--success);
      background: var(--success);
      color: #052e16;
      box-shadow: 0 0 0 3px rgba(34, 197, 94, .28);
    }
    .mw-stepper-step.is-workflow-current .mw-stepper-node {
      border-color: var(--success);
      background: rgba(34, 197, 94, .12);
      color: var(--success);
    }
    .mw-stepper-step.is-skipped .mw-stepper-node {
      border-color: rgba(148, 163, 184, .35);
      background: rgba(148, 163, 184, .12);
      color: var(--muted);
    }
    .mw-stepper-label {
      font-size: .72rem;
      font-weight: 600;
      line-height: 1.25;
      color: var(--muted);
    }
    .mw-stepper-step.is-progress .mw-stepper-label,
    .mw-stepper-step.is-complete .mw-stepper-label {
      color: var(--success);
    }
    .mw-stepper-step.is-viewing .mw-stepper-label {
      color: var(--text);
      font-weight: 700;
    }
    .mw-stepper-step.is-workflow-current .mw-stepper-label {
      color: var(--success);
    }
    .mw-step-ahead-notice {
      margin: 0 0 .75rem;
      padding: .65rem .75rem;
      border-radius: calc(var(--radius) - 2px);
      border: 1px solid rgba(59, 130, 246, .28);
      background: rgba(59, 130, 246, .08);
      font-size: .82rem;
      line-height: 1.5;
      color: var(--text);
    }
    .mw-step-body {
      padding: 1.15rem 0 0;
      border-top: 1px solid rgba(148, 163, 184, .16);
    }
    .mw-step-eyebrow {
      margin: 0 0 .4rem;
      font-size: .68rem;
      font-weight: 700;
      letter-spacing: .09em;
      text-transform: uppercase;
      color: var(--muted);
    }
    .mw-step-live-hint {
      display: inline-flex;
      margin: 0 0 .65rem;
      border-radius: 999px;
      padding: .2rem .55rem;
      font-size: .68rem;
      font-weight: 700;
      border: 1px solid rgba(34, 197, 94, .32);
      background: var(--success-bg);
      color: var(--success);
    }
    .mw-step-footer {
      display: flex;
      flex-direction: column;
      gap: .75rem;
      margin-top: 1.35rem;
      padding-top: 1rem;
      border-top: 1px solid rgba(148, 163, 184, .16);
    }
    .mw-step-footer-nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
    }
    .mw-step-footer-nav-end {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: .75rem;
      min-height: 2rem;
    }
    .mw-step-prev {
      border: none;
      background: none;
      padding: .35rem 0;
      font-family: inherit;
      font-size: .88rem;
      font-weight: 600;
      color: var(--success);
      cursor: pointer;
    }
    .mw-step-prev:hover:not(:disabled) {
      text-decoration: underline;
    }
    .mw-step-prev:disabled {
      opacity: .35;
      cursor: not-allowed;
    }
    .mw-step-footer-center {
      flex: 0 1 auto;
      text-align: right;
    }
    .mw-step-jump {
      border: none;
      background: none;
      padding: 0;
      font-family: inherit;
      font-size: .78rem;
      font-weight: 600;
      color: var(--muted);
      text-decoration: underline;
      cursor: pointer;
    }
    .mw-step-jump:hover {
      color: var(--text);
    }
    .mw-step-next {
      min-width: 7.5rem;
    }
    .mw-step-footer-hint {
      margin: 0;
      padding: .6rem .75rem;
      border-radius: calc(var(--radius) - 2px);
      border: 1px solid rgba(148, 163, 184, .22);
      background: rgba(148, 163, 184, .06);
      font-size: .78rem;
      line-height: 1.45;
      color: var(--muted);
    }
    .mw-step-footer-meta {
      margin: 0;
      padding-top: .15rem;
      font-size: .72rem;
      line-height: 1.4;
      color: var(--muted);
    }
    @media (max-width: 560px) {
      .mw-stepper-step {
        min-width: 2.75rem;
      }
      .mw-stepper-label {
        font-size: .62rem;
      }
      .mw-stepper-node {
        width: 2rem;
        height: 2rem;
        font-size: .72rem;
      }
    }
    .core-update-headline {
      margin: 0;
      font-size: 1.05rem;
      font-weight: 650;
      color: var(--text);
      line-height: 1.35;
    }
    .core-update-guide {
      margin: .45rem 0 0;
      font-size: .85rem;
      line-height: 1.6;
      color: var(--muted);
    }
    .core-update-version {
      margin: .65rem 0 0;
      line-height: 1.5;
    }
    .core-update-preview-panel {
      margin-top: 1rem;
      padding: .85rem;
      border-radius: calc(var(--radius) - 2px);
      border: 1px solid rgba(59, 130, 246, .28);
      background: rgba(59, 130, 246, .06);
    }
    .core-update-preview-links {
      display: flex;
      flex-wrap: wrap;
      gap: .5rem;
      margin-top: .65rem;
    }
    .core-update-preview-picker {
      margin-top: .65rem;
    }
    .preview-tenant-select {
      width: 100%;
      max-width: 28rem;
      padding: .5rem .65rem;
      border-radius: var(--radius);
      border: 1px solid var(--border);
      background: rgba(15, 23, 42, .45);
      color: var(--text);
      font-size: .85rem;
    }
    .core-update-preview-warn {
      margin: .55rem 0 0;
      padding: .55rem .65rem;
      border-radius: calc(var(--radius) - 2px);
      border: 1px solid rgba(234, 179, 8, .32);
      background: rgba(234, 179, 8, .08);
      color: var(--warning);
      font-size: .78rem;
      line-height: 1.5;
    }
    .mw-step-pr-link {
      margin: .85rem 0 0;
    }
    .mw-step-pr-link a {
      font-size: .88rem;
      font-weight: 600;
      color: var(--accent);
      text-decoration: none;
    }
    .mw-step-pr-link a:hover {
      text-decoration: underline;
    }
    .mw-ai-repair-panel {
      margin-top: 1rem;
      padding: .9rem;
      border-radius: calc(var(--radius) - 2px);
      border: 1px solid rgba(148, 163, 184, .22);
      background: rgba(15, 23, 42, .35);
    }
    .mw-ai-repair-actions {
      display: flex;
      flex-wrap: wrap;
      gap: .5rem;
      margin-top: .65rem;
    }
    .mw-ai-repair-result {
      margin-top: .75rem;
      padding: .75rem;
      border-radius: calc(var(--radius) - 2px);
      border: 1px solid rgba(148, 163, 184, .2);
      background: rgba(2, 6, 23, .55);
      max-height: 22rem;
      overflow: auto;
    }
    .mw-ai-repair-result.is-loading {
      color: var(--muted);
      font-size: .85rem;
    }
    .mw-ai-repair-result.is-success {
      border-color: rgba(34, 197, 94, .35);
    }
    .mw-ai-repair-result.is-error {
      border-color: rgba(239, 68, 68, .35);
    }
    .mw-ai-repair-result pre {
      margin: 0;
      white-space: pre-wrap;
      word-break: break-word;
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      font-size: .78rem;
      line-height: 1.55;
      color: var(--text);
    }
    .mw-advanced-actions {
      margin-top: .85rem;
    }
    .mw-advanced-actions summary {
      cursor: pointer;
      color: var(--muted);
      font-size: .78rem;
      font-weight: 650;
    }
    .mw-advanced-actions summary:hover {
      color: var(--text);
    }
    .mw-advanced-actions-body {
      display: flex;
      flex-wrap: wrap;
      gap: .5rem;
      margin-top: .65rem;
    }
    .mw-ai-repair-meta {
      margin: .5rem 0 0;
      font-size: .72rem;
      color: var(--muted);
      line-height: 1.45;
    }
  </style>
  <style>
    .history-wrap { overflow: visible; }
    .history-scroll {
      max-height: 20rem;
      overflow: auto;
      border: 1px solid rgba(148, 163, 184, .18);
      border-radius: var(--radius);
    }
    .history-footnote {
      margin: .65rem 0 0;
      font-size: .75rem;
      color: var(--muted);
      line-height: 1.5;
    }
    .history-table {
      width: 100%;
      border-collapse: collapse;
      font-size: .8rem;
    }
    .history-table th,
    .history-table td {
      text-align: left;
      padding: .55rem .4rem;
      border-bottom: 1px solid var(--border);
      vertical-align: top;
    }
    .history-table th { color: var(--muted); font-weight: 600; }
    :global(.sr-only) {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }
    .history-badge-live {
      display: inline-block;
      padding: .1rem .4rem;
      border-radius: 999px;
      background: var(--success-bg);
      color: var(--success);
      border: 1px solid rgba(34,197,94,.22);
      font-size: .72rem;
      font-weight: 600;
    }
    :global(.history-table th:last-child),
    :global(.history-table td:last-child) {
      text-align: right;
      width: 3rem;
    }
    :global(.history-actions) { position: relative; display: inline-flex; justify-content: flex-end; }
    :global(.history-kebab) {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 2rem;
      height: 2rem;
      padding: 0;
      border: 1px solid var(--border);
      border-radius: 999px;
      background: rgba(255, 255, 255, .04);
      color: var(--text);
      cursor: pointer;
      font-size: 1.35rem;
      font-weight: 700;
      line-height: 1;
      letter-spacing: .08em;
    }
    :global(.history-kebab:hover),
    :global(.history-kebab:focus-visible) {
      background: var(--surface);
      outline: none;
    }
    :global(.history-actions-menu) {
      position: absolute;
      right: 0;
      top: calc(100% + .45rem);
      min-width: 220px;
      padding: .45rem;
      border: 1px solid var(--border);
      border-radius: 14px;
      background: var(--bg-card);
      box-shadow: 0 24px 70px rgba(0, 0, 0, .55);
      z-index: 200;
    }
    :global(.history-actions-menu.hidden) { display: none; }
    :global(.history-actions-menu button),
    :global(.history-actions-menu a) {
      display: flex;
      align-items: center;
      width: 100%;
      min-height: 2.45rem;
      padding: .6rem .75rem;
      border: 0;
      border-radius: 10px;
      background: transparent;
      color: var(--text);
      text-align: left;
      text-decoration: none;
      font: inherit;
      font-size: .88rem;
      cursor: pointer;
      white-space: nowrap;
    }
    :global(.history-actions-menu button:hover),
    :global(.history-actions-menu a:hover) { background: var(--bg-card-hover); }
    :global(.history-actions-menu .danger) { color: var(--danger); }
    .history-modal.hidden,
    :global(.history-modal.hidden) { display: none; }
    .history-modal {
      position: fixed;
      inset: 0;
      z-index: 10000;
      display: grid;
      place-items: center;
      padding: 1rem;
    }
    .history-modal-backdrop {
      position: absolute;
      inset: 0;
      background: rgba(2, 6, 23, .86);
      backdrop-filter: blur(6px);
    }
    .history-modal-panel {
      position: relative;
      width: min(560px, calc(100vw - 2rem));
      max-height: min(720px, calc(100vh - 2rem));
      overflow: auto;
      padding: 1.35rem;
      border-radius: 18px;
      border: 1px solid var(--border);
      background: var(--bg-card);
      color: var(--text);
      box-shadow: 0 24px 80px rgba(0, 0, 0, .6);
    }
    .history-modal-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 1rem;
    }
    .history-modal-header h2 { margin: 0; }
    .history-modal-close {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 2rem;
      padding: .4rem .75rem;
      border: 1px solid var(--border);
      border-radius: 999px;
      background: rgba(255, 255, 255, .06);
      color: var(--text);
      cursor: pointer;
      font: inherit;
      font-size: .85rem;
      font-weight: 600;
      line-height: 1;
    }
    .history-modal-close:hover { background: rgba(255, 255, 255, .1); }
  </style>

  <script define:vars={{ cleanupDeletesUnassigned }}>
    function shouldAutoPollCoreUpdateStatus(status, opts) {
      if (opts?.prepareInFlight || opts?.aiRepairInFlight) return true;
      return status === "preparing" || status === "deploying";
    }

    function renderTrafficLightBanner(adminState) {
      const light = adminState.trafficLight || "amber";
      const label = adminState.trafficLightLabel || "Checking status";
      let hint = "Core updates run daily at 06:00 UTC. You will get email when something needs you.";
      if (light === "green") {
        hint = "Preview the site, then click Approve merge. Production stays unchanged until you approve.";
      } else if (light === "red") {
        hint = adminState.autopilotBlockedReason || "Autopilot blocked this update to protect tenant data. Retry Autopilot once, defer the update, or ask a developer.";
      } else if (adminState.status === "preparing" || adminState.status === "deploying") {
        hint = "The CTO bot is working. This page refreshes automatically.";
      }
      return (
        '<div class="core-update-traffic is-' +
        escapeAttr(light) +
        '" role="status" aria-live="polite">' +
        '<span class="core-update-traffic-dot" aria-hidden="true"></span>' +
        '<div><p class="core-update-traffic-label">' +
        escapeHtml(label) +
        "</p>" +
        '<p class="core-update-traffic-hint">' +
        escapeHtml(hint) +
        "</p></div></div>"
      );
    }

    function buildCoreUpdateNowAction(adminState, opts) {
      if (!adminState) {
        return {
          kind: "idle",
          headline: "",
          detail: "",
          primaryLabel: null,
          primaryDisabled: true,
          showSpinner: false,
          reassurance: null,
        };
      }

      if (opts?.prepareInFlight || adminState.status === "preparing") {
        return {
          kind: "preparing",
          headline: "Merge test running",
          detail:
            adminState.nextActionText ||
            "GitHub is running the merge test and safety checks. This page updates automatically.",
          primaryLabel: null,
          primaryDisabled: true,
          showSpinner: true,
          reassurance:
            "You already started prepare. Do not click Prepare again — wait for this page to advance.",
        };
      }

      if (opts?.aiRepairInFlight) {
        return {
          kind: "repair",
          headline: "Autopilot in progress",
          detail:
            opts.aiRepairDetail ||
            "GitHub Actions is resolving conflicts and verifying the build. This page updates automatically.",
          primaryLabel: null,
          primaryDisabled: true,
          showSpinner: true,
          reassurance:
            "Do not approve the merge yet. When repair finishes and checks pass, this step will unlock preview.",
        };
      }

      if (adminState.status === "deploying") {
        return {
          kind: "deploy_wait",
          headline: adminState.title || "Production deploy in progress",
          detail:
            adminState.nextActionText ||
            "The approved update is deploying. Refresh status until the live builder catches up.",
          primaryLabel: "Refresh status",
          primaryDisabled: false,
          showSpinner: true,
          reassurance: "No further approval is needed right now.",
        };
      }

      if (adminState.canPrepare) {
        return {
          kind: "prepare",
          headline: "Start the safe update",
          detail:
            adminState.nextActionText ||
            "Click Prepare once to run the merge test. Production stays unchanged until you approve the merge.",
          primaryLabel: "Prepare safe update",
          primaryDisabled: false,
          showSpinner: false,
          reassurance: "You only need to click Prepare once. The page will move forward automatically.",
        };
      }

      if (adminState.canCopyPrompt) {
        return {
          kind: "repair",
          headline: adminState.title || "Fix required before preview",
          detail:
            adminState.nextActionText ||
            "Retry Autopilot once for mechanical fixes, defer the update, or ask a developer to resolve the pull request.",
          primaryLabel: adminState.actionLabel || "Retry Autopilot",
          primaryDisabled: false,
          showSpinner: false,
          reassurance: "Autopilot blocks red updates to protect tenant data. Do not approve until conflicts and checks are resolved.",
        };
      }

      if (adminState.canApprove) {
        const prLabel =
          typeof adminState.prNumber === "number"
            ? "PR #" + adminState.prNumber
            : "the safe update PR";
        return {
          kind: "approve",
          headline: adminState.title || "Ready to approve",
          detail:
            adminState.nextActionText ||
            "Preview on the deploy preview if needed, then approve " + prLabel + ".",
          primaryLabel: adminState.actionLabel || "Approve merge",
          primaryDisabled: false,
          showSpinner: false,
          reassurance: "Approving merges to main and triggers the production deploy.",
        };
      }

      if (adminState.canPreview) {
        return {
          kind: "preview",
          headline: adminState.title || "Preview before approving",
          detail:
            adminState.nextActionText ||
            "Open the deploy preview and check the tenant site, then continue to approve.",
          primaryLabel: "Refresh status",
          primaryDisabled: false,
          showSpinner: false,
          reassurance: null,
        };
      }

      if (adminState.status === "up_to_date") {
        return {
          kind: "idle",
          headline: adminState.title || "Up to date",
          detail: adminState.description || "No update action is needed.",
          primaryLabel: null,
          primaryDisabled: true,
          showSpinner: false,
          reassurance: null,
        };
      }

      return {
        kind: "refresh",
        headline: adminState.title || "Check update status",
        detail:
          adminState.nextActionText ||
          adminState.description ||
          "Refresh status to see the latest workflow step.",
        primaryLabel: adminState.actionLabel || "Refresh status",
        primaryDisabled: false,
        showSpinner: false,
        reassurance: null,
      };
    }

    window.currentAdminUpdateState = null;
    window.coreUpdatePrepareInFlight = false;

    function toast(msg, ok) {
      const el = document.getElementById("toast");
      if (!el) return;
      el.textContent = msg;
      el.className = ok ? "toast-ok" : "toast-err";
      el.style.display = "block";
      setTimeout(() => (el.style.display = "none"), 5000);
    }

    async function api(path, opts, timeoutMs = 55000) {
      const controller = new AbortController();
      const timer = setTimeout(() => controller.abort(), timeoutMs);
      try {
        const res = await fetch(path, { ...opts, signal: controller.signal });
        const text = await res.text();
        try {
          return JSON.parse(text);
        } catch {
          return { ok: false, error: text || "Bad response (" + res.status + ")" };
        }
      } catch (err) {
        const message =
          err && typeof err === "object" && err.name === "AbortError"
            ? "Request timed out. Try Refresh status again."
            : err instanceof Error
              ? err.message
              : "Request failed";
        return { ok: false, error: message };
      } finally {
        clearTimeout(timer);
      }
    }

    document.getElementById("logoutBtn")?.addEventListener("click", async () => {
      await fetch("/api/auth/logout", { method: "POST" });
      window.location.href = "/login";
    });

    document.addEventListener("click", async (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;

      const menuButton = target.closest("[data-history-menu]");
      if (menuButton instanceof HTMLElement) {
        const index = menuButton.getAttribute("data-history-menu");
        const menu = index ? document.getElementById("historyMenu" + index) : null;
        const willOpen = menu?.classList.contains("hidden");
        closeHistoryMenus();
        if (menu && willOpen) menu.classList.remove("hidden");
        return;
      }

      const changelogButton = target.closest("[data-history-changelog]");
      if (changelogButton instanceof HTMLElement) {
        const row = latestHistoryRows[Number(changelogButton.getAttribute("data-history-changelog"))];
        closeHistoryMenus();
        if (row) showChangelog(row);
        return;
      }

      const restoreButton = target.closest("[data-history-restore]");
      if (restoreButton instanceof HTMLElement) {
        const row = latestHistoryRows[Number(restoreButton.getAttribute("data-history-restore"))];
        closeHistoryMenus();
        if (row) showRestoreWarning(row);
        return;
      }

      const confirmRestoreButton = target.closest("[data-confirm-history-restore]");
      if (confirmRestoreButton instanceof HTMLElement) {
        const deployId = confirmRestoreButton.getAttribute("data-confirm-history-restore");
        if (deployId) {
          confirmRestoreButton.setAttribute("disabled", "true");
          confirmRestoreButton.textContent = "Restoring...";
          await restoreHistoryBuild(deployId);
        }
        return;
      }

      if (target.closest("[data-history-modal-close]")) {
        closeHistoryModal();
        return;
      }

      if (!target.closest(".history-actions")) closeHistoryMenus();
    });

    let latestHistoryRows = [];

    function escapeHtml(value) {
      return String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");
    }

    function escapeAttr(value) {
      return escapeHtml(value).replaceAll("`", "&#096;");
    }

    function formatHistoryDate(value) {
      if (!value) return "—";
      const d = new Date(value);
      if (Number.isNaN(d.getTime())) return "—";
      return d.toLocaleString();
    }

    function renderUpdateHistory(rows) {
      const area = document.getElementById("historyArea");
      if (!area) return;

      if (!rows || rows.length === 0) {
        area.innerHTML = '<p class="text-sm text-muted" style="margin:0;">No update history yet.</p>';
        return;
      }

      latestHistoryRows = rows;
      const productionBranchLabel = (window.currentProductionBranch || "main").trim();
      const productionBranchKey = productionBranchLabel.toLowerCase();
      const htmlRows = rows
        .map((row, index) => {
          const commit = row.commitRef ? String(row.commitRef).slice(0, 7) : "—";
          const version = row.version || "—";
          const state = row.status === "live"
            ? '<span class="history-badge-live">Live</span>'
            : "Previous";
          const restoreNote = row.republished
            ? '<div class="text-xs text-muted" style="margin-top:.25rem;">Restored/republished from build created ' + escapeHtml(formatHistoryDate(row.originalDeployDate)) + "</div>"
            : "";
          const branch = row.branch || "—";
          const isProductionBranch =
            String(row.branch || "").trim().toLowerCase() === productionBranchKey;
          const previewAction = row.deployUrl
            ? '<a href="' + escapeAttr(row.deployUrl) + '" target="_blank" rel="noopener noreferrer">Open build preview</a>'
            : "";
          const restoreAction =
            row.status !== "live" && isProductionBranch
              ? '<button type="button" class="danger" data-history-restore="' + index + '">Restore as live</button>'
              : "";
          return (
            "<tr>" +
            "<td>" + escapeHtml(formatHistoryDate(row.date)) + restoreNote + "</td>" +
            "<td>" + escapeHtml(version) + "</td>" +
            "<td>" + state + "</td>" +
            "<td class=\"mono\">" + escapeHtml(commit) + "</td>" +
            "<td>" + escapeHtml(branch) + "</td>" +
            '<td><div class="history-actions">' +
            '<button type="button" class="history-kebab" data-history-menu="' + index + '" aria-label="Open row actions" title="More actions">...</button>' +
            '<div class="history-actions-menu hidden" id="historyMenu' + index + '">' +
            previewAction +
            '<button type="button" data-history-changelog="' + index + '">Changelog</button>' +
            restoreAction +
            "</div></div></td>" +
            "</tr>"
          );
        })
        .join("");

      const footnote =
        rows.length === 0
          ? "No core version milestones found on " + escapeHtml(productionBranchLabel) + " yet."
          : "Showing " + rows.length + " core version" + (rows.length === 1 ? "" : "s") + " on " + escapeHtml(productionBranchLabel) + " (newest deploy per version). Routine redeploys are hidden.";

      area.innerHTML =
        "<div class=\"history-scroll\">" +
        "<table class=\"history-table\">" +
        "<thead><tr><th>Date</th><th>Version</th><th>Status</th><th>Commit</th><th>Branch</th><th><span class=\"sr-only\">Actions</span></th></tr></thead>" +
        "<tbody>" +
        htmlRows +
        "</tbody>" +
        "</table>" +
        "</div>" +
        "<p class=\"history-footnote\">" + footnote + "</p>";
    }

    function closeHistoryMenus() {
      document.querySelectorAll(".history-actions-menu").forEach((menu) => menu.classList.add("hidden"));
    }

    function closeHistoryModal() {
      const modal = document.getElementById("historyModal");
      if (modal) modal.classList.add("hidden");
      const body = document.getElementById("historyModalBody");
      if (body) body.innerHTML = "";
      const actions = document.getElementById("historyModalActions");
      if (actions) {
        actions.classList.add("hidden");
        actions.innerHTML = "";
      }
    }

    function showHistoryModal(title, bodyHtml, actionsHtml) {
      const modal = document.getElementById("historyModal");
      const modalTitle = document.getElementById("historyModalTitle");
      const body = document.getElementById("historyModalBody");
      const actions = document.getElementById("historyModalActions");
      if (!modal || !modalTitle || !body || !actions) return;
      modalTitle.textContent = title;
      body.innerHTML = bodyHtml;
      actions.innerHTML = actionsHtml || "";
      actions.classList.toggle("hidden", !actionsHtml);
      modal.classList.remove("hidden");
    }

    function showChangelog(row) {
      const items = Array.isArray(row.changelog) && row.changelog.length > 0
        ? row.changelog
        : ["This build updated the builder code."];
      const details = [
        '<p style="margin-top:0;color:var(--text);font-weight:600;">What changed in this build?</p>',
        '<ul style="margin:.5rem 0 1rem;padding-left:1.25rem;">' + items.map((item) => '<li style="margin:.35rem 0;">' + escapeHtml(item) + "</li>").join("") + "</ul>",
        '<p class="text-xs text-muted" style="margin-bottom:0;">Build: <span class="mono">' + escapeHtml(row.commitRef ? String(row.commitRef).slice(0, 7) : row.id) + "</span></p>",
      ].join("");
      showHistoryModal("Changelog", details, "");
    }

    function showRestoreWarning(row) {
      const buildLabel = row.commitRef ? String(row.commitRef).slice(0, 7) : row.id;
      const body = [
        '<p style="margin-top:0;color:var(--danger);font-weight:600;">You are about to restore a previous builder build.</p>',
        "<p>This will switch the live MasjidWeb builder to the selected build. Tenant sites may start serving this version shortly after confirmation.</p>",
        '<p><strong>Selected build:</strong> <span class="mono">' + escapeHtml(buildLabel) + "</span></p>",
        "<p><strong>Published:</strong> " + escapeHtml(formatHistoryDate(row.date)) + "</p>",
        "<p>Please only continue if the latest build is broken or you intentionally want to roll back.</p>",
      ].join("");
      const actions =
        '<button type="button" class="btn btn-ghost" data-history-modal-close>Cancel</button>' +
        '<button type="button" class="btn btn-primary" data-confirm-history-restore="' + escapeAttr(row.id) + '">Yes, restore this build</button>';
      showHistoryModal("Restore previous build?", body, actions);
    }

    async function restoreHistoryBuild(deployId) {
      const data = await api("/api/updates/rollback", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ deployId }),
      });
      if (data.ok) {
        toast(data.message || "Build restored.", true);
        closeHistoryModal();
        await runUpdateCheck();
      } else {
        toast(data.error || data.message || "Could not restore build", false);
      }
    }

    const PREVIEW_TENANT_STORAGE_KEY = "mw_core_update_preview_tenant_slug";
    const DEFAULT_PREVIEW_TENANT_SLUG = "masjidemo1";

    function getStoredPreviewTenantSlug() {
      try {
        const value = localStorage.getItem(PREVIEW_TENANT_STORAGE_KEY);
        return value && String(value).trim() ? String(value).trim() : DEFAULT_PREVIEW_TENANT_SLUG;
      } catch {
        return DEFAULT_PREVIEW_TENANT_SLUG;
      }
    }

    function setStoredPreviewTenantSlug(slug) {
      try {
        if (slug) localStorage.setItem(PREVIEW_TENANT_STORAGE_KEY, slug);
      } catch {
        /* ignore */
      }
    }

    function previewTenantOptionLabel(option) {
      if (!option) return "";
      if (option.slug === DEFAULT_PREVIEW_TENANT_SLUG) return "MasjidDemo1 (template)";
      const name = option.businessName ? String(option.businessName).trim() : "";
      return name ? name + " (" + option.slug + ")" : option.slug;
    }

    function getCurrentUpdatePhase(phases) {
      if (!Array.isArray(phases)) return null;
      return phases.find((phase) => phase.status === "current") || null;
    }

    function getPhaseByStep(phases, step) {
      if (!Array.isArray(phases)) return null;
      return phases.find((phase) => phase.step === step) || null;
    }

    function getWorkflowStep(phases) {
      const current = getCurrentUpdatePhase(phases);
      return current && current.step ? current.step : 1;
    }

    const CORE_UPDATE_STEP_COUNT = 4;
    const CORE_UPDATE_VIEWED_STEP_KEY = "mw_core_update_viewed_step";
    const CORE_UPDATE_LAST_WORKFLOW_KEY = "mw_core_update_last_workflow_step";
    const CORE_UPDATE_STEPPER_LABELS = ["Prepare", "Fix", "Preview", "Approve"];
    const CORE_UPDATE_POLL_MS = 5000;
    const CORE_UPDATE_POLL_MAX_MS = 10 * 60 * 1000;
    let coreUpdatePollTimer = null;
    let coreUpdatePollDeadline = 0;
    let aiRepairPollTimer = null;
    let aiRepairPollDeadline = 0;
    let aiRepairWatchActive = false;
    let lastAiRepairWasInFlight = false;

    function stopAiRepairPolling() {
      if (aiRepairPollTimer) {
        clearInterval(aiRepairPollTimer);
        aiRepairPollTimer = null;
      }
      aiRepairPollDeadline = 0;
    }

    async function fetchAiRepairStatus() {
      const data = await api("/api/updates/ai-repair-status", {}, 15000);
      if (data.ok !== true) return false;

      const prevInFlight = isAiRepairInFlight(window.currentAiRepairRun);
      window.currentAiRepairRun = data.aiRepairRun || null;
      window.currentAiRepairSummary = data.aiRepairSummary || null;
      const inFlight = isAiRepairInFlight(window.currentAiRepairRun);

      if (window.currentAdminUpdateState && window.currentUpdateCheckData) {
        refreshCoreUpdateView();
      }

      if (prevInFlight && !inFlight && window.currentAdminUpdateState?.canCopyPrompt) {
        await runUpdateCheck({ silent: true });
      }

      lastAiRepairWasInFlight = inFlight;
      return inFlight;
    }

    function shouldWatchAiRepair(adminState) {
      return Boolean(
        aiRepairWatchActive ||
          isAiRepairInFlight(window.currentAiRepairRun) ||
          (adminState && adminState.canCopyPrompt && lastAiRepairWasInFlight),
      );
    }

    function startAiRepairPolling() {
      stopAiRepairPolling();
      aiRepairPollDeadline = Date.now() + CORE_UPDATE_POLL_MAX_MS;
      aiRepairPollTimer = setInterval(async () => {
        if (Date.now() > aiRepairPollDeadline) {
          stopAiRepairPolling();
          return;
        }
        const state = window.currentAdminUpdateState;
        if (!shouldWatchAiRepair(state)) {
          stopAiRepairPolling();
          return;
        }
        await fetchAiRepairStatus();
      }, CORE_UPDATE_POLL_MS);
    }

    function shouldAutoPollCoreUpdate(adminState) {
      return shouldAutoPollCoreUpdateStatus(adminState && adminState.status, {
        prepareInFlight: window.coreUpdatePrepareInFlight === true,
      });
    }

    function isAiRepairInFlight(run) {
      return Boolean(
        run &&
          (run.status === "queued" || run.status === "in_progress" || run.status === "pending"),
      );
    }

    function aiRepairOutcomeClass(run) {
      if (isAiRepairInFlight(run)) return "is-loading";
      if (run && run.conclusion === "success") return "is-success";
      if (run && run.conclusion === "failure") return "is-error";
      return "";
    }

    function stopCoreUpdatePolling() {
      if (coreUpdatePollTimer) {
        clearInterval(coreUpdatePollTimer);
        coreUpdatePollTimer = null;
      }
      coreUpdatePollDeadline = 0;
    }

    function startCoreUpdatePolling() {
      stopCoreUpdatePolling();
      coreUpdatePollDeadline = Date.now() + CORE_UPDATE_POLL_MAX_MS;
      coreUpdatePollTimer = setInterval(async () => {
        if (Date.now() > coreUpdatePollDeadline) {
          stopCoreUpdatePolling();
          return;
        }
        const state = window.currentAdminUpdateState;
        if (!shouldAutoPollCoreUpdate(state)) {
          stopCoreUpdatePolling();
          return;
        }
        await runUpdateCheck({ silent: true });
      }, CORE_UPDATE_POLL_MS);
    }

    function getStoredViewedStep() {
      const n = parseInt(sessionStorage.getItem(CORE_UPDATE_VIEWED_STEP_KEY) || "", 10);
      return n >= 1 && n <= CORE_UPDATE_STEP_COUNT ? n : null;
    }

    function setStoredViewedStep(step) {
      sessionStorage.setItem(CORE_UPDATE_VIEWED_STEP_KEY, String(step));
    }

    function resolveViewedStep(adminState) {
      const workflowStep = getWorkflowStep(adminState.phases || []);
      let lastWorkflow = parseInt(sessionStorage.getItem(CORE_UPDATE_LAST_WORKFLOW_KEY) || "", 10);
      sessionStorage.setItem(CORE_UPDATE_LAST_WORKFLOW_KEY, String(workflowStep));
      if (!Number.isNaN(lastWorkflow) && workflowStep > lastWorkflow) {
        setStoredViewedStep(workflowStep);
        return workflowStep;
      }
      const stored = getStoredViewedStep();
      const viewed = stored || workflowStep;
      if (viewed > workflowStep) return workflowStep;
      return viewed;
    }

    function shouldShowPreviewBlock(adminState, viewedStep) {
      if (!adminState || viewedStep !== 3) return false;
      if ((adminState.canPreview || adminState.canApprove) && adminState.preview) return true;
      const phase = getPhaseByStep(adminState.phases, 3);
      return Boolean(phase && (phase.status === "current" || phase.status === "done"));
    }

    function shouldShowAiRepairBlock(adminState, viewedStep) {
      if (!adminState?.canCopyPrompt) return false;
      const workflowStep = getWorkflowStep(adminState.phases || []);
      return viewedStep === 2 || (viewedStep === workflowStep && workflowStep === 2);
    }

    function renderAiRepairPanelHtml(aiRepairRun, aiRepairSummary) {
      const saved = window.lastAiRepairReply || "";
      const liveSummary = aiRepairSummary || "";
      const showPanel = saved || liveSummary || aiRepairRun;
      const hidden = showPanel ? "" : " hidden";
      const loading = window.aiRepairLoading || isAiRepairInFlight(aiRepairRun) ? " is-loading" : "";
      const outcomeClass = aiRepairOutcomeClass(aiRepairRun);
      let statusHtml = "";
      if (liveSummary || aiRepairRun) {
        const runLink =
          aiRepairRun && aiRepairRun.htmlUrl
            ? '<p class="mw-ai-repair-meta text-xs text-muted"><a href="' +
              escapeHtml(aiRepairRun.htmlUrl) +
              '" target="_blank" rel="noopener noreferrer">Open this workflow run</a></p>'
            : "";
        statusHtml =
          runLink +
          "<pre>" +
          escapeHtml(liveSummary || saved || "Checking automated repair status…") +
          "</pre>";
      } else if (saved) {
        statusHtml =
          '<p class="mw-ai-repair-meta text-xs text-muted">Last response' +
          (window.lastAiRepairModel ? " · " + escapeHtml(window.lastAiRepairModel) : "") +
          "</p><pre>" +
          escapeHtml(saved) +
          "</pre>";
      }
      return (
        '<div class="mw-ai-repair-panel">' +
        '<p class="text-xs text-muted" style="margin:0;line-height:1.55;">Use <strong>Retry Autopilot</strong> above to start deterministic repair on GitHub (rerere + package-lock regeneration where safe). If Autopilot reports tenant-sensitive conflicts, it uploads an invariant report and a developer is required. Production is not merged until you approve.</p>' +
        '<details class="mw-advanced-actions"><summary>Advanced actions</summary>' +
        '<div class="mw-advanced-actions-body">' +
        '<button type="button" id="copilotEscalationBtn" class="btn btn-ghost btn-sm">Escalate to Copilot</button>' +
        '<button type="button" id="assignCopilotBtn" class="btn btn-ghost btn-sm">Assign Copilot</button>' +
        '<button type="button" id="copyAiRepairPromptBtn" class="btn btn-ghost btn-sm">Copy prompt</button>' +
        "</div></details>" +
        '<div id="aiRepairResult" class="mw-ai-repair-result' +
        hidden +
        loading +
        outcomeClass +
        '">' +
        statusHtml +
        "</div></div>"
      );
    }

    async function copyAiRepairPrompt() {
      const state = window.currentAdminUpdateState || {};
      const prompt =
        state.agentPrompt ||
        state.nextActionText ||
        "Resolve the MasjidWeb safe core update.";
      try {
        await navigator.clipboard.writeText(prompt);
        toast("Copied AI repair prompt.", true);
      } catch {
        setApplyUpdateResult(
          "Copy this AI repair prompt:<br /><br />" + escapeHtml(prompt).replaceAll("\n", "<br />"),
          true,
        );
      }
    }

    async function runAiRepair(opts = {}) {
      const state = window.currentAdminUpdateState || {};
      const prNumber = typeof state.prNumber === "number" ? state.prNumber : null;
      const copilotEscalationMode = opts.copilotEscalationMode || "none";
      const repairMode = opts.repairMode || "autopilot";
      const isCopilotEscalation = copilotEscalationMode !== "none";
      const isPremiumAiRepair = repairMode === "premium_ai";
      if (!prNumber) {
        toast("No active safe-update PR to repair.", false);
        return;
      }
      const runBtn = document.getElementById("runAiRepairBtn");
      const nowBtn = document.getElementById("runAiRepairNowBtn");
      const issueBtn = document.getElementById("copilotEscalationBtn");
      const issueNowBtn = document.getElementById("copilotEscalationNowBtn");
      const premiumBtn = document.getElementById("premiumAiRepairNowBtn");
      const assignBtn = document.getElementById("assignCopilotBtn");
      const resultEl = document.getElementById("aiRepairResult");
      const activeBtn = isPremiumAiRepair
        ? premiumBtn
        : isCopilotEscalation
          ? copilotEscalationMode === "assign"
            ? assignBtn
            : issueBtn || issueNowBtn
          : runBtn || nowBtn;
      const buttons = [runBtn, nowBtn, issueBtn, issueNowBtn, premiumBtn, assignBtn].filter(Boolean);
      buttons.forEach((button) => {
        button.disabled = true;
      });
      if (activeBtn) {
        activeBtn.textContent = isPremiumAiRepair ? "Starting premium…" : isCopilotEscalation ? "Escalating…" : "Starting…";
      }
      window.aiRepairLoading = true;
      if (resultEl) {
        resultEl.classList.remove("hidden");
        resultEl.classList.add("is-loading");
        resultEl.innerHTML = isPremiumAiRepair
          ? "<pre>Dispatching Premium AI Repair report workflow…</pre>"
          : isCopilotEscalation
            ? "<pre>Dispatching Copilot escalation workflow…</pre>"
            : "<pre>Dispatching GitHub Actions repair…</pre>";
      }

      const res = await api("/api/updates/ai-repair", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ prNumber, copilotEscalationMode, repairMode }),
      });

      window.aiRepairLoading = false;
      buttons.forEach((button) => {
        button.disabled = false;
      });
      if (runBtn) runBtn.textContent = "Retry Autopilot";
      if (nowBtn) nowBtn.textContent = state.actionLabel || "Retry Autopilot";
      if (premiumBtn) premiumBtn.textContent = "Premium AI Repair";
      if (issueBtn) issueBtn.textContent = "Escalate to Copilot";
      if (issueNowBtn) issueNowBtn.textContent = "Escalate to Copilot";
      if (assignBtn) assignBtn.textContent = "Assign Copilot";

      if (!resultEl) return;

      resultEl.classList.remove("is-loading");
      resultEl.classList.remove("hidden");

      if (res.ok === true) {
        const message =
          typeof res.message === "string"
            ? res.message
            : isCopilotEscalation
              ? "Copilot escalation requested. GitHub issue/comment will be created; approval stays blocked until CI is green."
              : isPremiumAiRepair
                ? "Premium AI Repair report started on GitHub."
                : "Autopilot mechanical repair started on GitHub.";
        window.lastAiRepairReply = message;
        window.lastAiRepairModel = "";
        const workflowLink =
          typeof res.workflowUrl === "string"
            ? '<p class="mw-ai-repair-meta text-xs text-muted"><a href="' +
              escapeHtml(res.workflowUrl) +
              '" target="_blank" rel="noopener noreferrer">View workflow runs</a></p>'
            : "";
        const disclaimer =
          typeof res.disclaimer === "string"
            ? '<p class="mw-ai-repair-meta text-xs text-muted">' + escapeHtml(res.disclaimer) + "</p>"
            : "";
        resultEl.innerHTML = disclaimer + workflowLink + "<pre>" + escapeHtml(message) + "</pre>";
        toast(isCopilotEscalation ? "Copilot escalation requested." : isPremiumAiRepair ? "Premium AI Repair started." : "Automated repair started on GitHub.", true);
        aiRepairWatchActive = true;
        await fetchAiRepairStatus();
        startAiRepairPolling();
        return;
      }

      const err =
        typeof res.error === "string"
          ? res.error
          : isCopilotEscalation
            ? "Copilot escalation failed. Check GitHub Actions on the builder repo."
            : isPremiumAiRepair
              ? "Premium AI Repair failed. Check the workflow report/logs on the builder repo."
              : "Automated repair failed. Check GitHub Actions on the builder repo or wait for the CTO bot email.";
      const workflowLink =
        typeof res.workflowUrl === "string"
          ? '<p class="mw-ai-repair-meta text-xs text-muted"><a href="' +
            escapeHtml(res.workflowUrl) +
            '" target="_blank" rel="noopener noreferrer">Workflow</a></p>'
          : "";
      resultEl.innerHTML = workflowLink + "<pre>" + escapeHtml(err) + "</pre>";
      toast(err, false);
    }

    function renderPreviewTenantPickerHtml(options, selectedSlug) {
      const list = Array.isArray(options) ? options : [];
      if (list.length === 0) return "";
      const current = selectedSlug || getStoredPreviewTenantSlug();
      const optionsHtml = list
        .map((option) => {
          const slug = String(option.slug || "");
          const selected = slug === current ? " selected" : "";
          return (
            '<option value="' +
            escapeAttr(slug) +
            '"' +
            selected +
            ">" +
            escapeHtml(previewTenantOptionLabel(option)) +
            "</option>"
          );
        })
        .join("");
      return (
        '<div class="core-update-preview-picker">' +
        '<label for="previewTenantSelect" class="text-xs text-muted" style="display:block;margin-bottom:.35rem;font-weight:600;">Preview as</label>' +
        '<select id="previewTenantSelect" class="preview-tenant-select">' +
        optionsHtml +
        "</select></div>"
      );
    }

    function stepperConnectorFilled(phases, beforeStep, workflowStep) {
      if (beforeStep < 1) return false;
      const prev = getPhaseByStep(phases, beforeStep);
      if (!prev) return beforeStep < workflowStep;
      if (prev.status === "done") return true;
      if (prev.status === "skipped" && beforeStep < workflowStep) return true;
      return beforeStep < workflowStep;
    }

    function stepperStepClass(phase, step, viewedStep, workflowStep) {
      const classes = ["mw-stepper-step"];
      if (step === viewedStep) classes.push("is-viewing");
      if (phase.status === "skipped") {
        classes.push("is-skipped");
        return classes.join(" ");
      }
      const doneOrPast = phase.status === "done" || step < workflowStep;
      if (doneOrPast) {
        if (step !== viewedStep) classes.push("is-complete");
        return classes.join(" ");
      }
      if (step === workflowStep) {
        if (step === viewedStep) classes.push("is-progress");
        else classes.push("is-workflow-current");
      }
      return classes.join(" ");
    }

    function stepperNodeContent(phase, step, workflowStep) {
      if (phase.status === "done" || step < workflowStep) return "\u2713";
      if (phase.status === "skipped") return "\u2014";
      return String(step);
    }

    function renderStepper(phases, viewedStep, workflowStep) {
      const list = Array.isArray(phases) ? phases : [];
      const parts = [];
      for (let step = 1; step <= CORE_UPDATE_STEP_COUNT; step += 1) {
        if (step > 1) {
          const filled = stepperConnectorFilled(list, step - 1, workflowStep);
          parts.push(
            '<li class="mw-stepper-connector' + (filled ? " is-filled" : "") + '" aria-hidden="true"></li>',
          );
        }
        const phase = getPhaseByStep(list, step) || { step, status: "upcoming" };
        const shortLabel = CORE_UPDATE_STEPPER_LABELS[step - 1] || String(step);
        parts.push(
          '<li class="' +
            stepperStepClass(phase, step, viewedStep, workflowStep) +
            '">' +
            '<button type="button" class="mw-stepper-node" data-goto-step="' +
            escapeAttr(step) +
            '"' +
            (step > workflowStep ? " disabled" : "") +
            ' aria-current="' +
            (step === viewedStep ? "step" : "false") +
            '">' +
            escapeHtml(stepperNodeContent(phase, step, workflowStep)) +
            "</button>" +
            '<span class="mw-stepper-label">' +
            escapeHtml(shortLabel) +
            "</span></li>",
        );
      }
      return (
        '<nav class="mw-stepper" aria-label="Core update progress"><ol class="mw-stepper-list">' +
        parts.join("") +
        "</ol></nav>"
      );
    }

    function renderNowActionPanel(adminState, prepareInFlight, aiRepairRun, aiRepairSummary) {
      const action = buildCoreUpdateNowAction(adminState, {
        prepareInFlight,
        aiRepairInFlight: isAiRepairInFlight(aiRepairRun),
        aiRepairDetail: aiRepairSummary || null,
      });
      if (action.kind === "idle" && adminState && adminState.status === "up_to_date") {
        return (
          '<div class="mw-now-action is-waiting" role="status">' +
          '<p class="mw-now-action-label">Status</p>' +
          '<h3 class="mw-now-action-headline">' +
          escapeHtml(action.headline) +
          "</h3>" +
          '<p class="mw-now-action-detail">' +
          escapeHtml(action.detail) +
          "</p></div>"
        );
      }
      if (action.kind === "idle") return "";

      const waitingClass = action.showSpinner ? " is-waiting" : "";
      let html = '<div class="mw-now-action' + waitingClass + '" role="status" aria-live="polite">';
      html += '<p class="mw-now-action-label">Your next action</p>';
      html += '<h3 class="mw-now-action-headline">';
      if (action.showSpinner) html += '<span class="mw-now-spinner" aria-hidden="true"></span>';
      html += escapeHtml(action.headline) + "</h3>";
      html += '<p class="mw-now-action-detail">' + escapeHtml(action.detail) + "</p>";
      if (action.reassurance) {
        html +=
          '<p class="mw-now-action-reassurance">' + escapeHtml(action.reassurance) + "</p>";
      }
      html += '<div class="mw-now-action-buttons">';
      if (action.primaryLabel) {
        let btnId = "nowActionRefreshBtn";
        if (action.kind === "prepare") btnId = "prepareSafeUpdateBtn";
        else if (action.kind === "approve") btnId = "approveSafeUpdateBtn";
        else if (action.kind === "repair") btnId = "runAiRepairNowBtn";
        html +=
          '<button type="button" id="' +
          btnId +
          '" class="btn btn-primary btn-sm"' +
          (action.primaryDisabled ? " disabled" : "") +
          ">" +
          escapeHtml(action.primaryLabel) +
          "</button>";
      }
      if (action.kind === "repair" && adminState && adminState.canCopyPrompt) {
        html +=
          '<button type="button" id="premiumAiRepairNowBtn" class="btn btn-ghost btn-sm">Premium AI Repair</button>';
        html +=
          '<details class="mw-advanced-actions"><summary>Advanced actions</summary><div class="mw-advanced-actions-body">' +
          '<button type="button" id="copilotEscalationNowBtn" class="btn btn-ghost btn-sm">Escalate to Copilot</button>' +
          '<button type="button" id="copyAiRepairPromptNowBtn" class="btn btn-ghost btn-sm">Copy prompt</button>' +
          "</div></details>";
      }
      if (adminState && adminState.prUrl) {
        html +=
          '<a class="btn btn-ghost btn-sm" href="' +
          escapeAttr(adminState.prUrl) +
          '" target="_blank" rel="noopener noreferrer">Open pull request</a>';
      }
      const previewHref =
        adminState &&
        (adminState.preview?.publicSiteOnPreview || adminState.previewUrl);
      if (adminState && adminState.canPreview && previewHref) {
        const label = adminState.preview?.tenantLabel || "tenant";
        html +=
          '<a class="btn btn-ghost btn-sm" href="' +
          escapeAttr(previewHref) +
          '" target="_blank" rel="noopener noreferrer">Open ' +
          escapeHtml(label) +
          " preview</a>";
      }
      html += "</div></div>";
      return html;
    }

    function renderStepPanel(adminState, data, viewedStep) {
      const phases = adminState.phases || [];
      const phase = getPhaseByStep(phases, viewedStep);
      const workflowStep = getWorkflowStep(phases);
      if (!phase) return "";

      const isLiveStep = viewedStep === workflowStep;
      // Step panel explains what this step is. The live action + status lives in the
      // "Your next action" banner above, so we intentionally do NOT repeat
      // adminState.title / nextActionText here (that caused duplicate copy + buttons).
      let headline = phase.title;
      let guide = phase.detail;
      if (phase.status === "skipped" && viewedStep === 2) {
        guide = "No merge conflicts were detected for this update. You can move on to preview when the pull request is ready.";
      }

      let html = '<div class="mw-step-body">';
      html +=
        '<p class="mw-step-eyebrow">Step ' +
        escapeHtml(viewedStep) +
        " of " +
        escapeHtml(CORE_UPDATE_STEP_COUNT) +
        "</p>";
      if (viewedStep > workflowStep) {
        const workflowLabel = CORE_UPDATE_STEPPER_LABELS[workflowStep - 1] || String(workflowStep);
        html +=
          '<p class="mw-step-ahead-notice">You are reading ahead. The live workflow is still on <strong>' +
          escapeHtml(workflowLabel) +
          "</strong> (step " +
          escapeHtml(workflowStep) +
          '). Use <strong>Jump to current step</strong> below before taking action.</p>';
      } else if (viewedStep < workflowStep && phase.status === "done") {
        const workflowLabel = CORE_UPDATE_STEPPER_LABELS[workflowStep - 1] || String(workflowStep);
        html +=
          '<p class="mw-step-ahead-notice">This step is already complete. The live workflow is on <strong>' +
          escapeHtml(workflowLabel) +
          "</strong> (step " +
          escapeHtml(workflowStep) +
          '). Use <strong>Jump to current step</strong> or the actions below the wizard.</p>';
        guide =
          "Safe update preparation already started. You do not need to prepare again — continue on the current step.";
      } else if (isLiveStep) {
        html += '<span class="mw-step-live-hint">Current step</span>';
      }
      html += '<h3 class="core-update-headline">' + escapeHtml(headline) + "</h3>";
      html += '<p class="core-update-guide">' + escapeHtml(guide) + "</p>";

      if (shouldShowAiRepairBlock(adminState, viewedStep)) {
        html += renderAiRepairPanelHtml(window.currentAiRepairRun, window.currentAiRepairSummary);
      }

      if (shouldShowPreviewBlock(adminState, viewedStep)) {
        const selectedSlug = (data && data.previewTenant && data.previewTenant.slug) || getStoredPreviewTenantSlug();
        const preview = adminState.preview;
        html += '<div class="core-update-preview-panel">';
        html += renderPreviewTenantPickerHtml(data && data.previewTenantOptions, selectedSlug);
        if (preview) {
          if (preview.publicSiteOnPreview) {
            html +=
              '<p class="text-xs text-muted" style="margin:.55rem 0 0;">Deploy preview URL: <span class="mono">' +
              escapeHtml(preview.publicSiteOnPreview) +
              "</span></p>";
          }
          html +=
            '<p class="text-xs text-muted" style="margin:.35rem 0 0;">Tenant subdomains like <span class="mono">' +
            escapeHtml(preview.productionPublicUrl) +
            "</span> still show the live build until you approve this merge.</p>";
        }
        html += "</div>";
      }

      html += "</div>";
      return html;
    }

    function requiresStepActionBeforeNext(viewedStep, workflowStep, adminState) {
      if (!adminState || viewedStep !== workflowStep) return false;
      if (viewedStep === 1 && adminState.canPrepare) return true;
      if (viewedStep === 2 && adminState.canCopyPrompt) return true;
      if (viewedStep === 4 && adminState.canApprove) return true;
      return false;
    }

    function getWizardNextNav(viewedStep, workflowStep, adminState) {
      if (viewedStep >= CORE_UPDATE_STEP_COUNT) {
        return { disabled: true, label: "Next step", hint: null, hideNext: true };
      }
      if (requiresStepActionBeforeNext(viewedStep, workflowStep, adminState)) {
        return {
          disabled: true,
          label: "Next step",
          hint: "Finish the step above to unlock the next step.",
          hideNext: true,
        };
      }
      if (viewedStep < workflowStep) {
        return { disabled: false, label: "Review next step", hint: null, hideNext: false };
      }
      return {
        disabled: true,
        label: "Next step",
        hint: "Future steps stay collapsed until this update reaches them.",
        hideNext: true,
      };
    }

    function renderWizardNav(viewedStep, workflowStep, adminState, versionLine) {
      const backDisabled = viewedStep <= 1;
      const nextNav = getWizardNextNav(viewedStep, workflowStep, adminState);
      let navEnd = "";
      if (viewedStep !== workflowStep) {
        navEnd =
          '<button type="button" class="mw-step-jump" data-goto-step="' +
          escapeAttr(workflowStep) +
          '">Jump to current step</button>';
      }
      if (!nextNav.hideNext) {
        navEnd +=
          '<button type="button" id="coreUpdateStepNext" class="btn btn-ghost btn-sm mw-step-next"' +
          (nextNav.disabled ? " disabled" : "") +
          ">" +
          escapeHtml(nextNav.label) +
          " &gt;</button>";
      }
      let html =
        '<div class="mw-step-footer">' +
        '<div class="mw-step-footer-nav">' +
        '<button type="button" id="coreUpdateStepBack" class="mw-step-prev"' +
        (backDisabled ? " disabled" : "") +
        ">&lt; Previous</button>" +
        '<div class="mw-step-footer-nav-end">' +
        navEnd +
        "</div></div>";
      if (nextNav.hint) {
        html +=
          '<p class="mw-step-footer-hint">' + escapeHtml(nextNav.hint) + "</p>";
      }
      if (versionLine) {
        html +=
          '<p class="mw-step-footer-meta text-xs text-muted">' +
          escapeHtml(versionLine) +
          "</p>";
      }
      html += "</div>";
      return html;
    }

    function buildVersionLine(data) {
      if (!data || data.ok !== true) return "";
      const latest = data.latestReleaseVersion;
      const live = data.deployedPackageVersion || data.forkPackageVersion;
      if (!latest && !live) return "";
      let line = "Release " + (latest || "—") + " · Live builder " + (live || "—");
      if (data.deployCommitRef && data.deployedPackageVersion) {
        line += " · commit " + String(data.deployCommitRef).slice(0, 7);
      }
      return line;
    }

    function renderCoreUpdateWizard(adminState, data, viewedStep) {
      const phases = adminState.phases || [];
      const step = Math.max(1, Math.min(CORE_UPDATE_STEP_COUNT, viewedStep || resolveViewedStep(adminState)));
      const productionPillClass = adminState.productionStatus === "Deploy pending" ? " pending" : "";
      const versionLine = buildVersionLine(data);

      let html = '<div class="core-update-state" data-viewed-step="' + escapeAttr(step) + '">';
      html += renderTrafficLightBanner(adminState);
      html +=
        '<div class="core-update-topline"><span class="core-update-pill' +
        productionPillClass +
        '">' +
        escapeHtml(adminState.productionStatus || "Production unchanged") +
        "</span></div>";

      if (phases.length > 0) {
        const workflowStep = getWorkflowStep(phases);
        html += renderNowActionPanel(
          adminState,
          window.coreUpdatePrepareInFlight === true,
          window.currentAiRepairRun,
          window.currentAiRepairSummary,
        );
        html += renderStepper(phases, step, workflowStep);
        html += renderStepPanel(adminState, data, step);
        html += renderWizardNav(step, workflowStep, adminState, versionLine);
      } else {
        html += '<h3 class="core-update-headline">' + escapeHtml(adminState.title) + "</h3>";
        html += '<p class="core-update-guide">' + escapeHtml(adminState.description) + "</p>";
        if (versionLine) {
          html +=
            '<p class="mw-step-footer-meta text-xs text-muted" style="margin-top:1rem;">' +
            escapeHtml(versionLine) +
            "</p>";
        }
      }

      html += "</div>";
      return html;
    }

    function syncCoreUpdateActionButtons(adminState) {
      const applyButton = document.getElementById("applyBuilderUpdateBtn");
      const safeUpdatePrLink = document.getElementById("safeUpdatePrLink");
      const openPreviewBtn = document.getElementById("openPreviewBtn");
      const actionsRow = document.querySelector(".core-update-actions");
      if (!adminState) return;

      const hasWizard = Array.isArray(adminState.phases) && adminState.phases.length > 0;
      if (actionsRow) {
        if (hasWizard) actionsRow.classList.add("hidden");
        else actionsRow.classList.remove("hidden");
      }
      if (!applyButton) return;

      if (safeUpdatePrLink) {
        if (!hasWizard && adminState.prUrl) {
          safeUpdatePrLink.setAttribute("href", adminState.prUrl);
          safeUpdatePrLink.classList.remove("hidden");
        } else {
          safeUpdatePrLink.classList.add("hidden");
        }
      }

      if (openPreviewBtn) {
        const previewHref =
          adminState.preview?.publicSiteOnPreview || adminState.previewUrl;
        if (!hasWizard && adminState.canPreview && previewHref) {
          openPreviewBtn.setAttribute("href", previewHref);
          const label = adminState.preview?.tenantLabel || "tenant";
          openPreviewBtn.textContent = "Open " + label + " homepage preview";
          openPreviewBtn.classList.remove("hidden");
        } else {
          openPreviewBtn.classList.add("hidden");
        }
      }

      if (!hasWizard) {
        const primaryEnabled =
          adminState.canPrepare ||
          adminState.status === "preparing" ||
          adminState.canCopyPrompt ||
          adminState.canPreview ||
          adminState.canApprove;
        applyButton.textContent = adminState.actionLabel || "Refresh status";
        applyButton.disabled = !primaryEnabled && adminState.status !== "deploying";
      }
    }

    function refreshCoreUpdateView(nextStep) {
      const adminState = window.currentAdminUpdateState;
      const data = window.currentUpdateCheckData;
      const statusArea = document.getElementById("statusArea");
      if (!adminState || !statusArea) return;

      let viewed = nextStep;
      if (viewed == null) {
        viewed = resolveViewedStep(adminState);
      } else {
        viewed = Math.max(1, Math.min(CORE_UPDATE_STEP_COUNT, viewed));
        setStoredViewedStep(viewed);
      }
      window.coreUpdateViewedStep = viewed;
      statusArea.innerHTML = renderCoreUpdateWizard(adminState, data, viewed);
      syncCoreUpdateActionButtons(adminState);
    }

    async function runUpdateCheck(opts) {
      const silent = opts && opts.silent === true;
      const prevWorkflow = getWorkflowStep(
        (window.currentAdminUpdateState && window.currentAdminUpdateState.phases) || [],
      );
      const btn = document.getElementById("checkUpdatesBtn");
      if (!silent && btn) {
        btn.disabled = true;
        btn.innerHTML = '<span style="opacity:.6">Checking...</span>';
      }

      const previewSlug = getStoredPreviewTenantSlug();
      const statusUrl =
        "/api/updates/status?previewTenantSlug=" + encodeURIComponent(previewSlug);
      const data = await api(statusUrl);
      if (!silent && btn) {
        btn.disabled = false;
        btn.innerHTML = '<svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg> Refresh status';
      }

      const statusArea = document.getElementById("statusArea");
      if (!statusArea) return;

      const adminState = data.adminState || {
        status: data.ok === true && data.releaseAheadOfForkPackage ? "update_available" : data.ok === true ? "up_to_date" : "unknown_error",
        title: data.ok === true && data.releaseAheadOfForkPackage ? "Update available" : data.ok === true ? "Up to date" : "Update status unavailable",
        description: data.ok === true && data.releaseAheadOfForkPackage
          ? "A safe Ycode update can be prepared. Production will not change immediately."
          : data.ok === true
            ? "No action needed. Production is already on the latest known safe version."
            : "The admin dashboard could not read update status. Do not approve anything yet. Production is unchanged.",
        productionStatus: "Production unchanged",
        actionLabel: "Prepare safe update",
        nextActionText: "Refresh status or ask AI/operator to inspect the update dashboard.",
        agentPrompt: null,
        canPrepare: data.ok === true && data.releaseAheadOfForkPackage === true,
        canApprove: false,
        prUrl: null,
      };
      const selectedPreviewSlug = data.previewTenant?.slug || previewSlug;
      if (selectedPreviewSlug) setStoredPreviewTenantSlug(selectedPreviewSlug);

      window.currentAdminUpdateState = adminState;
      window.currentUpdateCheckData = data;
      window.currentProductionBranch = data.productionBranch || "main";

      if (
        adminState.status !== "update_available" ||
        adminState.prNumber ||
        adminState.canApprove ||
        adminState.canCopyPrompt ||
        adminState.status === "preparing"
      ) {
        window.coreUpdatePrepareInFlight = false;
      }

      refreshCoreUpdateView();

      if (adminState.canCopyPrompt) {
        await fetchAiRepairStatus();
      } else {
        window.currentAiRepairRun = null;
        window.currentAiRepairSummary = null;
        aiRepairWatchActive = false;
        lastAiRepairWasInFlight = false;
      }

      const newWorkflow = getWorkflowStep(adminState.phases || []);
      if (newWorkflow > prevWorkflow) {
        const label = CORE_UPDATE_STEPPER_LABELS[newWorkflow - 1] || String(newWorkflow);
        toast("Workflow advanced to step " + newWorkflow + ": " + label + ".", true);
      }

      if (shouldAutoPollCoreUpdate(adminState)) {
        startCoreUpdatePolling();
      } else {
        stopCoreUpdatePolling();
      }

      if (shouldWatchAiRepair(adminState)) {
        startAiRepairPolling();
      } else {
        stopAiRepairPolling();
      }

      if (data.ok !== true) {
        toast(adminState.description || data.error || "Update status unavailable", false);
        renderUpdateHistory([]);
        return;
      }

      renderUpdateHistory(Array.isArray(data.updateHistory) ? data.updateHistory : []);
      syncReversibleCheckpointUI(data.reversibleCheckpoint);
    }

    function syncReversibleCheckpointUI(checkpoint) {
      const btn = document.getElementById("rollbackFullUpdateBtn");
      const hint = document.getElementById("reversibleCheckpointHint");
      if (!btn || !hint) return;

      if (!checkpoint || !checkpoint.beforeDeployId) {
        btn.classList.add("hidden");
        hint.classList.add("hidden");
        hint.textContent = "";
        return;
      }

      btn.classList.remove("hidden");
      const parts = [];
      if (checkpoint.beforePackageVersion) {
        parts.push("pre-update version " + checkpoint.beforePackageVersion);
      }
      if (checkpoint.beforeMainSha) {
        parts.push("main " + String(checkpoint.beforeMainSha).slice(0, 7));
      }
      if (checkpoint.prNumber) {
        parts.push("PR #" + checkpoint.prNumber);
      }
      hint.textContent =
        "Reversible checkpoint recorded (" +
        parts.join(" · ") +
        "). Full rollback reverts the merge and restores the exact Netlify deploy from before approve. Database migrations are not reversed automatically.";
      hint.classList.remove("hidden");
    }

    function setApplyUpdateResult(message, ok, opts = {}) {
      const el = document.getElementById("applyUpdateResult");
      if (!el) return;

      const lines = [];
      if (opts.requiresTechAction === true) {
        lines.push(opts.adminMessage ? String(opts.adminMessage) : "Update paused for technical review.");
        lines.push("No action needed from platform admin.");
      } else if (opts.prUrl) {
        const label = opts.prNumber ? "Open conflict PR #" + opts.prNumber : "Open conflict PR";
        lines.push("Update paused: one merge conflict needs a one-time fix.");
        lines.push("Step 1: Open the conflict PR.");
        lines.push('<a href="' + String(opts.prUrl) + '" target="_blank" rel="noopener noreferrer">' + label + "</a>");
        lines.push("Step 2: Resolve conflicts and merge that PR on GitHub.");
        lines.push("Step 3: Return here and click Apply YCode update again.");
      } else {
        if (message) lines.push(String(message));
        if (opts.hint) lines.push(String(opts.hint));
      }

      if (opts.compareUrl && !opts.prUrl) {
        lines.push('<a href="' + String(opts.compareUrl) + '" target="_blank" rel="noopener noreferrer">Open compare view</a>');
      }

      el.innerHTML = lines.join("<br />");
      el.classList.remove("hidden");
      if (ok) {
        el.style.background = "var(--success-bg)";
        el.style.borderColor = "rgba(34,197,94,.2)";
        el.style.color = "var(--success)";
      } else {
        el.style.background = "rgba(239,68,68,.1)";
        el.style.borderColor = "rgba(239,68,68,.35)";
        el.style.color = "var(--danger)";
      }
    }

    async function postApproveSafeUpdate() {
      const state = window.currentAdminUpdateState || {};
      const prLabel = state.prNumber ? "PR #" + state.prNumber : "the safe update pull request";
      if (
        !confirm(
          "Approve and merge " +
            prLabel +
            " now? Production will deploy the new core after the merge build finishes.",
        )
      ) {
        return;
      }
      const btn = document.getElementById("approveSafeUpdateBtn");
      if (btn) {
        btn.disabled = true;
        btn.textContent = "Approving…";
      }
      const res = await api("/api/updates/approve-safe-update", { method: "POST" });
      if (btn) {
        btn.disabled = false;
        btn.textContent = state.actionLabel || "Approve merge";
      }
      if (res.ok) {
        setApplyUpdateResult(res.message || "Update approved.", true);
        toast(res.message || "Update approved.", true);
        await runUpdateCheck();
        startCoreUpdatePolling();
        return;
      }
      const err = res.error || res.message || "Could not approve update";
      setApplyUpdateResult(err, false);
      toast(err, false);
    }

    async function postPrepareSafeUpdate() {
      window.coreUpdatePrepareInFlight = true;
      refreshCoreUpdateView();

      const data = await api("/api/updates/prepare-safe-update", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
      });

      if (data.ok === true) {
        setApplyUpdateResult(data.message || "Safe update preparation has started. Production has not changed.", true);
        toast(data.message || "Safe update preparation has started.", true);
        await runUpdateCheck();
        startCoreUpdatePolling();
        return;
      }

      window.coreUpdatePrepareInFlight = false;
      refreshCoreUpdateView();

      const msg = typeof data.message === "string"
        ? data.message
        : typeof data.error === "string"
          ? data.error
          : "Could not prepare safe update";
      setApplyUpdateResult(msg, false);
      toast(msg, false);
    }

    document.getElementById("checkUpdatesBtn")?.addEventListener("click", runUpdateCheck);

    document.getElementById("statusArea")?.addEventListener("change", async (event) => {
      const target = event.target;
      if (!(target instanceof HTMLSelectElement) || target.id !== "previewTenantSelect") return;
      const slug = target.value?.trim();
      if (!slug) return;
      setStoredPreviewTenantSlug(slug);
      await runUpdateCheck();
    });

    document.getElementById("statusArea")?.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;

      const gotoBtn = target.closest("[data-goto-step]");
      if (gotoBtn instanceof HTMLElement && gotoBtn.dataset.gotoStep) {
        const nextStep = parseInt(gotoBtn.dataset.gotoStep, 10);
        const workflowStep = getWorkflowStep((window.currentAdminUpdateState && window.currentAdminUpdateState.phases) || []);
        if (nextStep > workflowStep) return;
        refreshCoreUpdateView(nextStep);
        return;
      }

      if (target.id === "coreUpdateStepBack" || target.closest("#coreUpdateStepBack")) {
        refreshCoreUpdateView((window.coreUpdateViewedStep || 1) - 1);
        return;
      }

      if (target.id === "coreUpdateStepNext" || target.closest("#coreUpdateStepNext")) {
        refreshCoreUpdateView((window.coreUpdateViewedStep || 1) + 1);
        return;
      }

      if (target.id === "runAiRepairBtn" || target.closest("#runAiRepairBtn")) {
        runAiRepair();
        return;
      }

      if (
        target.id === "copyAiRepairPromptBtn" ||
        target.closest("#copyAiRepairPromptBtn") ||
        target.id === "copyAiRepairPromptNowBtn" ||
        target.closest("#copyAiRepairPromptNowBtn")
      ) {
        copyAiRepairPrompt();
        return;
      }

      if (target.id === "copilotEscalationBtn" || target.closest("#copilotEscalationBtn")) {
        runAiRepair({ copilotEscalationMode: "issue" });
        return;
      }

      if (target.id === "assignCopilotBtn" || target.closest("#assignCopilotBtn")) {
        runAiRepair({ copilotEscalationMode: "assign" });
        return;
      }

      if (target.id === "prepareSafeUpdateBtn" || target.closest("#prepareSafeUpdateBtn")) {
        if (window.coreUpdatePrepareInFlight) return;
        if (!confirm("Prepare a safe Ycode update now? Production will not change immediately.")) return;
        postPrepareSafeUpdate();
        return;
      }

      if (target.id === "approveSafeUpdateBtn" || target.closest("#approveSafeUpdateBtn")) {
        postApproveSafeUpdate();
        return;
      }

      if (target.id === "runAiRepairNowBtn" || target.closest("#runAiRepairNowBtn")) {
        runAiRepair();
        return;
      }

      if (target.id === "copilotEscalationNowBtn" || target.closest("#copilotEscalationNowBtn")) {
        runAiRepair({ copilotEscalationMode: "issue" });
        return;
      }

      if (target.id === "premiumAiRepairNowBtn" || target.closest("#premiumAiRepairNowBtn")) {
        runAiRepair({ repairMode: "premium_ai" });
        return;
      }

      if (target.id === "nowActionRefreshBtn" || target.closest("#nowActionRefreshBtn")) {
        runUpdateCheck();
        return;
      }
    });

    const applyBuilderBtn = document.getElementById("applyBuilderUpdateBtn");
    applyBuilderBtn?.addEventListener("click", async () => {
      const state = window.currentAdminUpdateState || {};

      if (state.status === "preparing") {
        await runUpdateCheck();
        return;
      }

      if (state.status === "blocked_needs_resolution" || state.status === "checks_failed") {
        const viewed = window.coreUpdateViewedStep || 2;
        if (viewed !== 2) {
          refreshCoreUpdateView(2);
          setTimeout(() => runAiRepair(), 0);
          return;
        }
        await runAiRepair();
        return;
      }

      if ((state.status === "ready_to_approve" || state.status === "ready_to_preview") && state.canApprove) {
        const prLabel = state.prNumber ? "PR #" + state.prNumber : "the safe update pull request";
        if (
          !confirm(
            "Approve and merge " +
              prLabel +
              " now? Production will deploy the new core after the merge build finishes.",
          )
        ) {
          return;
        }
        applyBuilderBtn.disabled = true;
        applyBuilderBtn.textContent = "Approving…";
        const res = await api("/api/updates/approve-safe-update", { method: "POST" });
        applyBuilderBtn.disabled = false;
        if (res.ok) {
          setApplyUpdateResult(res.message || "Update approved.", true);
          toast(res.message || "Update approved.", true);
          setTimeout(runUpdateCheck, 2500);
        } else {
          const err = res.error || res.message || "Could not approve update";
          setApplyUpdateResult(err, false);
          toast(err, false);
        }
        await runUpdateCheck();
        return;
      }

      if (!state.canPrepare) {
        await runUpdateCheck();
        return;
      }

      if (!confirm("Prepare a safe Ycode update now? Production will not change immediately.")) return;
      applyBuilderBtn.disabled = true;
      applyBuilderBtn.textContent = "Preparing…";
      await postPrepareSafeUpdate();
      applyBuilderBtn.disabled = false;
      await runUpdateCheck();
    });

    const rollbackFullBtn = document.getElementById("rollbackFullUpdateBtn");
    rollbackFullBtn?.addEventListener("click", async () => {
      const msg =
        "Full rollback will:\n" +
        "1) Create and merge a git revert of the last approved safe-update PR\n" +
        "2) Restore the exact Netlify production deploy from before that approve\n\n" +
        "This does NOT reverse database migrations or tenant CMS data.\n\n" +
        "Continue?";
      if (!confirm(msg)) return;
      rollbackFullBtn.disabled = true;
      rollbackFullBtn.textContent = "Rolling back…";
      const res = await api("/api/updates/rollback-full-update", { method: "POST" });
      if (res.ok) {
        setApplyUpdateResult(res.message || "Full rollback complete.", true);
        toast(res.message || "Full rollback complete.", true);
        if (Array.isArray(res.caveats) && res.caveats.length) {
          setApplyUpdateResult(res.message + " Note: " + res.caveats.join(" "), true);
        }
        setTimeout(runUpdateCheck, 2500);
      } else {
        toast(res.error || res.message || "Full rollback failed", false);
        if (res.revertPrUrl) {
          setApplyUpdateResult(
            (res.error || "Partial failure") + " Revert PR: " + res.revertPrUrl,
            false,
          );
        }
      }
      rollbackFullBtn.disabled = false;
      rollbackFullBtn.textContent = "Full rollback to pre-update";
    });

    const cleanupOrphansBtn = document.getElementById("cleanupOrphansBtn");
    const rowCleanupResult = document.getElementById("rowCleanupResult");
    cleanupOrphansBtn?.addEventListener("click", async () => {
      const msg =
        "Remove CMS/YCode rows whose tenant_id no longer exists in tenant_registry, align Auth users (delete orphans / repair missing tenant_id from slug), and remove stale builder invites?" +
        (cleanupDeletesUnassigned
          ? " This server is also configured to DELETE Auth users with no tenant_id and no tenant_slug (except emails listed in AUTH_CLEANUP_PRESERVE_AUTH_EMAILS)."
          : "");
      if (!confirm(msg)) return;
      cleanupOrphansBtn.disabled = true;
      if (rowCleanupResult) rowCleanupResult.textContent = "Running database cleanup...";
      try {
        const res = await fetch("/api/cleanup-orphans", { method: "POST" });
        const data = await res.json();
        if (data.ok) {
          const rows = data.removed && data.removed.length
            ? data.removed.map((r) => r.table_name + ": " + r.removed).join(", ")
            : "none";
          const removed = typeof data.authUsersRemoved === "number" && data.authUsersRemoved > 0
            ? "; auth removed: " + data.authUsersRemoved
            : "";
          const repaired = typeof data.authUsersRepaired === "number" && data.authUsersRepaired > 0
            ? "; auth repaired: " + data.authUsersRepaired
            : "";
          const unassigned = typeof data.authUsersRemovedUnassigned === "number" && data.authUsersRemovedUnassigned > 0
            ? "; no-tenant auth removed: " + data.authUsersRemovedUnassigned
            : "";
          const summary = "Cleanup done: " + rows + removed + repaired + unassigned;
          if (rowCleanupResult) rowCleanupResult.textContent = summary;
          toast(summary, true);
        } else {
          if (rowCleanupResult) rowCleanupResult.textContent = data.error || "Cleanup failed";
          toast(data.error || "Cleanup failed", false);
        }
      } catch (err) {
        const message = err.message || "Cleanup failed";
        if (rowCleanupResult) rowCleanupResult.textContent = message;
        toast(message, false);
      } finally {
        cleanupOrphansBtn.disabled = false;
      }
    });

    runUpdateCheck();

    const cleanupDomainAliasesBtn = document.getElementById("cleanupDomainAliasesBtn");
    const domainCleanupResult = document.getElementById("domainCleanupResult");
    cleanupDomainAliasesBtn?.addEventListener("click", async () => {
      cleanupDomainAliasesBtn.disabled = true;
      if (domainCleanupResult) domainCleanupResult.textContent = "Checking for orphan subdomains...";
      try {
        const previewRes = await fetch("/api/cleanup-domain-aliases");
        const preview = await previewRes.json();
        if (!preview.ok) {
          if (domainCleanupResult) domainCleanupResult.textContent = preview.error || "Subdomain preview failed";
          toast(preview.error || "Subdomain preview failed", false);
          return;
        }

        const aliases = Array.isArray(preview.orphanAliases) ? preview.orphanAliases : [];
        if (aliases.length === 0) {
          if (domainCleanupResult) domainCleanupResult.textContent = "No orphan subdomains found.";
          toast("No orphan subdomains found", true);
          return;
        }

        const list = aliases.slice(0, 20).join("\n");
        const more = aliases.length > 20 ? "\n...and " + (aliases.length - 20) + " more" : "";
        if (!confirm("Remove these orphan Netlify tenant subdomains?\n\n" + list + more)) {
          if (domainCleanupResult) domainCleanupResult.textContent = "Cleanup cancelled. Found " + aliases.length + " orphan subdomain(s).";
          return;
        }

        if (domainCleanupResult) domainCleanupResult.textContent = "Removing " + aliases.length + " orphan subdomain(s)...";
        const cleanupRes = await fetch("/api/cleanup-domain-aliases", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ aliases }),
        });
        const cleanup = await cleanupRes.json();
        if (cleanup.ok) {
          const removedAliases = Array.isArray(cleanup.removed) ? cleanup.removed : [];
          const skippedAliases = Array.isArray(cleanup.skipped) ? cleanup.skipped : [];
          const skipped = skippedAliases.length ? "; skipped: " + skippedAliases.length : "";
          const summary = "Subdomain cleanup done: removed " + removedAliases.length + skipped;
          if (domainCleanupResult) domainCleanupResult.textContent = summary;
          toast(summary, true);
        } else {
          if (domainCleanupResult) domainCleanupResult.textContent = cleanup.error || "Subdomain cleanup failed";
          toast(cleanup.error || "Subdomain cleanup failed", false);
        }
      } catch (err) {
        const message = err.message || "Subdomain cleanup failed";
        if (domainCleanupResult) domainCleanupResult.textContent = message;
        toast(message, false);
      } finally {
        cleanupDomainAliasesBtn.disabled = false;
      }
    });
  </script>
</Layout>
