      const id = btn.dataset.deactivateId;
      const slug = btn.dataset.deactivateSlug;
      if (!confirm('Deactivate "' + slug + '"? Data stays in the database; the site can be reactivated later.')) return;
      btn.disabled = true;
      try {
        const res = await fetch("/api/tenants", {
          method: "PATCH",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ id, status: "deactivated" }),
        });
        const data = await res.json();
        if (data.ok) {
          toast("Tenant deactivated", true);
          setTimeout(() => location.reload(), 800);
        } else {
          toast(data.error || "Update failed", false);
          btn.disabled = false;
        }
      } catch (err) {
        toast(err.message || "Update failed", false);
        btn.disabled = false;
      }
    });
  });

  document.querySelectorAll("[data-activate-id]").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const id = btn.dataset.activateId;
      const slug = btn.dataset.activateSlug;
      if (!confirm('Reactivate "' + slug + '"?')) return;
      btn.disabled = true;
      try {
        const res = await fetch("/api/tenants", {
          method: "PATCH",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ id, status: "active" }),
        });
        const data = await res.json();
        if (data.ok) {
          toast("Tenant active", true);
          setTimeout(() => location.reload(), 800);
        } else {
          toast(data.error || "Update failed", false);
          btn.disabled = false;
        }
      } catch (err) {
        toast(err.message || "Update failed", false);
        btn.disabled = false;
      }
    });
  });

  document.querySelectorAll("[data-delete-id]").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const id = btn.dataset.deleteId;
      const slug = btn.dataset.deleteSlug;
      if (!confirm('Permanently delete tenant "' + slug + '", all site data, and remove its subdomain?')) return;
      btn.disabled = true;
      try {
        const res = await fetch("/api/tenants", {
          method: "DELETE",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ id }),
        });
        const data = await res.json();
        if (data.ok) {
          const cleanup = data.cleanup || {};
          const notes = [];
          if (cleanup.orphanRowsRemoved > 0) notes.push("orphan rows removed: " + cleanup.orphanRowsRemoved);
          if (cleanup.orphanSubdomainsRemoved > 0) notes.push("subdomains removed: " + cleanup.orphanSubdomainsRemoved);
          if (cleanup.authUsersRemoved > 0) notes.push("auth removed: " + cleanup.authUsersRemoved);
          if (cleanup.authUsersRepaired > 0) notes.push("auth repaired: " + cleanup.authUsersRepaired);
          if (cleanup.authUsersRemovedUnassigned > 0) {
            notes.push("no-tenant auth removed: " + cleanup.authUsersRemovedUnassigned);
          }
          const warnings = Array.isArray(data.warnings) && data.warnings.length
            ? "; warnings: " + data.warnings.length
            : "";
          toast(
            notes.length
              ? "Tenant deleted; cleanup complete (" + notes.join("; ") + warnings + ")"
              : "Tenant deleted; cleanup complete" + warnings,
            true,
          );
          setTimeout(() => location.reload(), 1200);
        } else {
          toast(data.error || "Delete failed", false);
          btn.disabled = false;
        }
      } catch (err) {
        toast(err.message || "Delete failed", false);
        btn.disabled = false;
      }
    });
  });

</script>
</Layout>
