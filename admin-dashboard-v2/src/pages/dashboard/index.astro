      const tenantId = menuButton.getAttribute("data-tenant-menu");
      const menu = tenantId ? document.getElementById("tenantMenu-" + tenantId) : null;
      const willOpen = menu?.classList.contains("hidden");
      closeTenantMenus();
      if (menu && willOpen) {
        positionTenantMenu(menu, menuButton);
        menuButton.setAttribute("aria-expanded", "true");
      }
      return;
    }

    if (target.closest(".tenant-actions-menu button, .tenant-actions-menu a")) {
      closeTenantMenus();
      return;
    }

    if (!target.closest(".tenant-row-actions") && !target.closest(".tenant-actions-menu")) closeTenantMenus();
  });

