    let data;
    try {
      data = await res.json();
    } catch {
      throw new Error("Server returned non-JSON (status " + res.status + ")");
    }
    if (!data.ok) {
      throw new Error(formatApiErrorPayload(data) || "Request failed (status " + res.status + ")");
