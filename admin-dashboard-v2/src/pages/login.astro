---
import Layout from "../layouts/Layout.astro";
---
<Layout title="Login — MasjidWeb Admin">
  <div style="display:flex;align-items:center;justify-content:center;min-height:100vh;padding:1.5rem;">
    <div style="width:100%;max-width:380px;">
      <!-- Brand -->
      <div style="text-align:center;margin-bottom:2rem;">
        <img src="/masjidweb-logo.svg" alt="MasjidWeb" width="48" height="48" style="display:inline-block;margin-bottom:.75rem;" />
        <h1 style="font-size:1.35rem;margin-bottom:.25rem;">MasjidWeb Admin</h1>
        <p style="font-size:.835rem;color:var(--text-muted);">Multi-tenant management dashboard</p>
      </div>

      <div class="card" style="padding:1.75rem;">
        <form id="loginForm">
          <div class="field">
            <label for="pw">Admin password</label>
            <input type="password" id="pw" name="password" required autofocus placeholder="Enter your password" />
          </div>
          <button type="submit" class="btn btn-primary" id="loginBtn" style="width:100%;margin-top:.25rem;">
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/></svg>
            Sign in
          </button>
          <p id="err" style="color:var(--danger);font-size:.8rem;margin-top:.65rem;display:none;text-align:center;"></p>
        </form>
      </div>

      <p style="text-align:center;font-size:.75rem;color:var(--text-muted);margin-top:1.25rem;">
        Subdomain-based multi-tenant architecture
      </p>
    </div>
  </div>

  <script>
    document.getElementById("loginForm")!.addEventListener("submit", async (e) => {
      e.preventDefault();
      const btn = document.getElementById("loginBtn") as HTMLButtonElement;
      btn.disabled = true;
      btn.innerHTML = '<span style="opacity:.7">Signing in…</span>';
      const pw = (document.getElementById("pw") as HTMLInputElement).value;
      try {
        const res = await fetch("/api/auth/login", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ password: pw }),
        });
        const data = await res.json();
        if (data.ok) {
          window.location.href = "/dashboard";
        } else {
          const el = document.getElementById("err")!;
          el.textContent = data.error || "Invalid password";
          el.style.display = "block";
          btn.disabled = false;
          btn.innerHTML = `<svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/></svg> Sign in`;
        }
      } catch (err: any) {
        const el = document.getElementById("err")!;
        el.textContent = err.message;
        el.style.display = "block";
        btn.disabled = false;
        btn.innerHTML = `<svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/></svg> Sign in`;
      }
    });
  </script>
</Layout>
